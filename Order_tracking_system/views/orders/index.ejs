<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item active"><%= isAdminOrOffice ? 'All Orders & Dispatch' : 'My Orders' %></li>
  </ol>
</nav>
<div id="app-root"></div>

<style>
  .count-card {
    cursor: pointer !important;
    transition: all 0.2s ease !important;
  }
  .count-card:hover {
    transform: translateY(-4px) !important;
    box-shadow: 0 8px 16px rgba(0,0,0,0.15) !important;
  }
  .count-card.disabled {
    cursor: default !important;
  }
  .count-card.disabled:hover {
    transform: none !important;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
  }
</style>

<script type="text/babel">
const { useState, useEffect, useRef } = React;
const IS_ADMIN = window._IS_ADMIN === 'true' || window._IS_ADMIN === true;
const CAN_VIEW_ALL = window._CAN_VIEW_ALL === 'true' || window._CAN_VIEW_ALL === true;
const IS_ADMIN_OR_OFFICE = window._IS_ADMIN_OR_OFFICE === 'true' || window._IS_ADMIN_OR_OFFICE === true;
const IS_DISPATCHER = window._IS_DISPATCHER === 'true' || window._IS_DISPATCHER === true;

const STATUS_CONFIG = {
  ORDER_PLACED:         { text: 'Order Placed',         icon: '🕐', bg: '#fd7e14', tc: '#fff' },
  ACCEPTED:             { text: 'Accepted',             icon: '✅', bg: '#0dcaf0', tc: '#000' },
  ON_HOLD:              { text: 'On Hold',              icon: '⏸️', bg: '#e57373', tc: '#fff' },
  FULLY_DISPATCHED:     { text: 'Fully Dispatched',     icon: '✅', bg: '#198754', tc: '#fff' },
  PARTIALLY_DISPATCHED: { text: 'Partially Dispatched', icon: '📦', bg: '#fd7e14', tc: '#fff' },
  DISPATCH_ON_HOLD:     { text: 'Dispatch on Hold',     icon: '⏸️', bg: '#e57373', tc: '#fff' },
  CANCELLED:            { text: 'Cancelled',            icon: '❌', bg: '#6c757d', tc: '#fff' },
};

const validatePhone=(val)=>val.replace(/[^0-9]/g,'').slice(0,10);
const isValidPhone=(val)=>/^\d{10}$/.test(val.replace(/[^0-9]/g,''));


function formatDateTime(value) {
  if (!value) return '—';
  const dt = new Date(value);
  if (Number.isNaN(dt.getTime())) return value;
  return new Intl.DateTimeFormat('en-IN', {
    day: '2-digit',
    month: 'short',
    year: 'numeric',
    hour: '2-digit',
    minute: '2-digit',
    second: '2-digit',
    hour12: true,
  }).format(dt);
}

function StatusBadge({ status }) {
  // status is the single order_status value from dealer_orders
  const cfg = STATUS_CONFIG[status] || { bg: '#6c757d', tc: '#fff', text: status };
  return (
    <span className="badge" style={{ background: cfg.bg, color: cfg.tc }}>
      {cfg.icon} {cfg.text}
    </span>
  );
}

function OnHoldModal({ order, onConfirm, onClose, requireReason }) {
  const [reason, setReason] = React.useState('');
  const [saving, setSaving] = React.useState(false);
  const [error, setError] = React.useState('');

  const handleConfirm = async () => {
    if (requireReason && !reason.trim()) {
      setError('Hold reason is required');
      return;
    }
    setSaving(true);
    await onConfirm(reason.trim());
    setSaving(false);
  };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)', overflowY: 'auto' }}>
      <div className="modal-dialog modal-dialog-centered">
        <div className="modal-content" style={{ marginTop: 'auto', marginBottom: 'auto' }}>
          <div className="modal-header bg-warning">
            <h5 className="modal-title">⏸️ Put Order #{order.order_id} On Hold</h5>
            <button type="button" className="btn-close" onClick={onClose}></button>
          </div>
          <div className="modal-body">
            <p className="text-muted mb-3 small">This order will be paused. {requireReason ? 'You must provide a reason.' : 'Only you can reopen it.'} Orders that are <strong>Accepted</strong> or <strong>Dispatched</strong> cannot be put on hold.</p>
            {error && <div className="alert alert-danger py-2 px-3 mb-3">{error}</div>}
            <div className="mb-1">
              <label className="form-label fw-semibold">
                Reason {requireReason && <span className="text-danger">*</span>}
                {!requireReason && <span className="text-muted fw-normal small">(optional)</span>}
              </label>
              <textarea
                className="form-control"
                rows="3"
                placeholder="e.g. Awaiting yard space, pending payment, Party request…"
                value={reason}
                onChange={e => { setReason(e.target.value); setError(''); }}
              />
            </div>
          </div>
          <div className="modal-footer">
            <button type="button" className="btn btn-secondary" onClick={onClose}>Cancel</button>
            <button type="button" className="btn btn-warning" disabled={saving || (requireReason && !reason.trim())}
              onClick={handleConfirm}>
              {saving && <span className="spinner-border spinner-border-sm me-1"></span>}
              Confirm Hold
            </button>
          </div>
        </div>
      </div>
    </div>
  );
}

function SummaryCard({ label, value, icon, borderColor, onClick, isDisabled }) {
  return (
    <div className="col-6 col-md-3 mb-3">
      <div
        className={`card border-0 shadow-sm h-100 count-card ${isDisabled ? 'disabled' : ''}`}
        style={{ borderLeft: `4px solid ${borderColor}`, cursor: isDisabled ? 'default' : 'pointer' }}
        onClick={onClick}
      >
        <div className="card-body d-flex align-items-center gap-3 py-3">
          <div style={{ fontSize: '2rem' }}>{icon}</div>
          <div>
            <div className="fs-4 fw-bold">{value}</div>
            <div className="text-muted small">{label}</div>
          </div>
        </div>
      </div>
    </div>
  );
}

function ViewOrderModal({ order, onClose }) {
  if (!order) return null;
  const d = order.dispatch;

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">
          <div className="modal-header bg-info text-white">
            <h5 className="modal-title">📋 Order #{order.order_id} — Details</h5>
            <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
          </div>
          <div className="modal-body" style={{ maxHeight: '70vh', overflowY: 'auto' }}>
            {/* Order Information */}
            <h6 className="fw-bold text-muted mb-3 text-uppercase small">Order Information</h6>
            <div className="row g-3 mb-4">
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Dealer</div>
                  <div className="fw-semibold">{order.dealer_name || '—'}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Order Date</div>
                  <div className="fw-semibold">{formatDateTime(order.order_date)}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Product</div>
                  <div className="fw-semibold">{order.product_name || '—'}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Quantity</div>
                  <div className="fw-semibold">{parseFloat(order.quantity || 0).toFixed(3)} MT</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Party</div>
                  <div className="fw-semibold">{order.party_name || '—'}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Status</div>
                  <div><StatusBadge status={order.order_status}/></div>
                </div>
              </div>
            </div>

            {/* Dispatch Information */}
            {d ? (
              <>
                <h6 className="fw-bold text-muted mb-3 text-uppercase small">Dispatch Information</h6>
                <div className="row g-3 mb-4">
                  <div className="col-md-6">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Vehicle Number</div>
                      <div className="fw-semibold">{d.dispatch_vehicle_number || '—'}</div>
                    </div>
                  </div>
                  <div className="col-md-6">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Driver Phone</div>
                      <div className="fw-semibold">{d.driver_phone || '—'}</div>
                    </div>
                  </div>
                  <div className="col-md-6">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Bilty Number</div>
                      <div className="fw-semibold">{d.bilty_number || '—'}</div>
                    </div>
                  </div>
                  <div className="col-md-6">
                    <div className="p-3 bg-light rounded">
                      <div className="text-muted small">Actual Loading Location</div>
                      <div className="fw-semibold">{d.actual_loading_location_code || '—'}</div>
                    </div>
                  </div>
                </div>

                {/* Receipt Image */}
                {d.image_url && (
                  <div className="mb-4">
                    <h6 className="fw-bold text-muted mb-3 text-uppercase small">📸 Dispatch Receipt</h6>
                    <div className="p-3 bg-light rounded">
                      <div className="text-center mb-3">
                        <img src={d.image_url} alt="Dispatch Receipt" style={{maxWidth: '100%', maxHeight: '300px', borderRadius: '8px'}} />
                      </div>
                      <div className="text-muted small">
                        {d.image_uploaded_at && <div>Uploaded: {formatDateTime(d.image_uploaded_at)}</div>}
                      </div>
                    </div>
                  </div>
                )}
