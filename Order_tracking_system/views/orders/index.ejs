}

function DispatchModal({ order, onClose, onRefresh }) {
  if (!order) return null;

  const [form, setForm] = useState({
    vehicle_number: order.dispatch?.dispatch_vehicle_number || order.dispatch_vehicle_number || '',
    driver_name: order.dispatch?.driver_name || order.dispatch_driver_name || '',
    driver_phone: order.dispatch?.driver_phone || order.dispatch_driver_phone || order.driver_phone || '',
    bilty_number: order.dispatch?.bilty_number || order.bilty_number || '',
    actual_loading_location_code: order.dispatch?.actual_loading_location_code || order.actual_loading_location_code || '',
    dispatch_comments: order.dispatch?.dispatch_comments || order.dispatch_comments || ''
  });

  const [saving, setSaving] = useState(false);
  const [err, setErr] = useState('');
  const [selectedFile, setSelectedFile] = useState(null);
  const [imagePreview, setImagePreview] = useState(null);
  const [uploading, setUploading] = useState(false);
  const [uploadProgress, setUploadProgress] = useState(0);
  const [uploadedImageUrl, setUploadedImageUrl] = useState(null);
  const [imageMetadata, setImageMetadata] = useState(null);
  const [currentReceiptUrl, setCurrentReceiptUrl] = useState(order.dispatch?.image_url || order.image_url);
  const [loadingLocations, setLoadingLocations] = useState([]);

  const galleryInputRef = useRef(null);
  const cameraInputRef = useRef(null);

  useEffect(() => {
    fetch('/api/codes/loading_location', { credentials: 'include' })
      .then(r => r.json())
      .then(data => setLoadingLocations(Array.isArray(data) ? data : []))
      .catch(e => {
        console.error('Failed to load locations:', e);
        setLoadingLocations([]);
      });
  }, []);

  const set = (k, v) => setForm(f => ({ ...f, [k]: v }));

  const handleFileSelect = async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;

    const validTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/gif', 'image/webp'];
    if (!validTypes.includes(file.type)) {
      setErr('Please select a valid image file (JPG, PNG, GIF, WebP)');
      return;
    }

    setSelectedFile(file);
    const reader = new FileReader();
    reader.onload = (evt) => setImagePreview(evt.target.result);
    reader.readAsDataURL(file);
    setErr('');
  };

  const uploadReceipt = async () => {
    if (!selectedFile) return;

    setUploading(true);
    setErr('');

    try {
      setUploadProgress(20);

      const presignedRes = await fetch('/api/dispatcher/presigned-url', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          order_id: order.order_id,
          dealer_id: order.dealer_id,
          file_name: selectedFile.name,
          file_type: selectedFile.type,
        }),
      });

      if (!presignedRes.ok) {
        const errorData = await presignedRes.json().catch(() => ({}));
        throw new Error(errorData.error || 'Failed to get presigned URL');
      }

      const { url: presignedUrl, s3Key, isLocal } = await presignedRes.json();
      setUploadProgress(40);

      let s3Url;

      if (isLocal) {
        const fileBase64 = await new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => {
            const dataUrl = reader.result;
            const base64 = dataUrl.includes(',') ? dataUrl.split(',')[1] : dataUrl;
            resolve(base64);
          };
          reader.onerror = reject;
          reader.readAsDataURL(selectedFile);
        });

        const localUploadRes = await fetch(presignedUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            filePath: s3Key,
            fileData: fileBase64,
            order_id: order.order_id,
            dealer_id: order.dealer_id
          })
        });

        if (!localUploadRes.ok) {
          throw new Error(`Upload failed: ${localUploadRes.status}`);
        }

        const localResult = await localUploadRes.json();
        s3Url = localResult.image_url;
      } else {
        const s3UploadRes = await fetch(presignedUrl, {
          method: 'PUT',
          body: selectedFile,
          headers: { 'Content-Type': selectedFile.type },
        });

        if (!s3UploadRes.ok) {
          throw new Error(`Upload failed: ${s3UploadRes.status}`);
        }

        // Try to get a read presigned URL, but fall back to the upload URL if it fails
        const s3Key_extracted = presignedUrl.split('/receipts/')[1]?.split('?')[0];
        if (s3Key_extracted) {
          try {
            const readUrlRes = await fetch('/api/dispatcher/presigned-read-url', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ s3Key: `receipts/${s3Key_extracted}` })
            });

            if (readUrlRes.ok) {
              const readResult = await readUrlRes.json();
              s3Url = readResult.url;
            } else {
              // Fallback: use the original presigned URL if read URL generation fails
              console.warn('Read presigned URL generation failed, using upload URL as fallback');
              s3Url = presignedUrl;
            }
          } catch (err) {
            console.warn('Error generating read presigned URL:', err.message, 'using upload URL');
            s3Url = presignedUrl;
          }
        } else {
          console.warn('S3 key extraction failed, using upload URL directly');
          s3Url = presignedUrl;
        }
      }

      setUploadProgress(100);
      setUploadedImageUrl(s3Url);
      setImageMetadata({
        image_url: s3Url,
        image_type: selectedFile.type,
        image_original_size: selectedFile.size,
        image_compressed_size: null,
      });
      setSelectedFile(null);
      setImagePreview(null);
      setUploading(false);
    } catch (error) {
      console.error('Upload error:', error);
      setErr(`Upload failed: ${error.message}`);
      setUploading(false);
      setUploadProgress(0);
    }
  };

  const handleDeleteCurrentReceipt = async () => {
    if (!confirm('Delete this receipt?')) return;

    try {
      const res = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch/receipt`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' }
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Failed to delete receipt');
      }

      setCurrentReceiptUrl(null);
    } catch (error) {
      setErr(error.message);
    }
  };

  const handleDownloadReceipt = async (imageUrl) => {
    try {
      const response = await fetch(imageUrl);
      if (!response.ok) throw new Error('Failed to download');

      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const link = document.createElement('a');
      link.href = url;

      const timestamp = new Date().toISOString().split('T')[0];
      const ext = imageUrl.includes('jpeg') || imageUrl.includes('jpg') ? 'jpg' : 'png';
      link.download = `Receipt_Order${order.order_id}_${timestamp}.${ext}`;

      document.body.appendChild(link);
      link.click();
      document.body.removeChild(link);
      window.URL.revokeObjectURL(url);
    } catch (error) {
      setErr('Failed to download receipt');
    }
  };

  const submit = async () => {
    if (!form.vehicle_number.trim()) return setErr('Vehicle number is required');
    if (!form.driver_phone.trim()) return setErr('Driver phone is required');
    if (!/^\d{10}$/.test(form.driver_phone.trim())) return setErr('Driver phone must be 10 digits');
    if (!form.bilty_number.trim()) return setErr('Bilty number is required');
    if (!form.actual_loading_location_code) return setErr('Actual loading location is required');

    setSaving(true);
    setErr('');

    try {
      const payload = {
        vehicle_number: form.vehicle_number,
        driver_name: form.driver_name,
        driver_phone: form.driver_phone,
        bilty_number: form.bilty_number,
        actual_loading_location_code: form.actual_loading_location_code
      };

      // Add image data if uploading new receipt
      if (uploadedImageUrl && imageMetadata) {
        payload.image_url = uploadedImageUrl;
        payload.image_type = imageMetadata.image_type || '';
        payload.image_original_size = imageMetadata.image_original_size || null;
        payload.image_compressed_size = imageMetadata.image_compressed_size || null;
      } else if (currentReceiptUrl && !uploadedImageUrl) {
        // Keep existing receipt if not uploading new one
        payload.image_url = currentReceiptUrl;
      } else if (uploadedImageUrl) {
        // Have uploaded URL but no metadata
        payload.image_url = uploadedImageUrl;
      }

      const res = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (!res.ok) {
        const error = await res.json();
        throw new Error(error.error || 'Save failed');
      }

      if (onRefresh) onRefresh();
      onClose();
    } catch (error) {
      setErr(error.message);
      setSaving(false);
    }
  };

  const d = order.dispatch;

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
      <div className="modal-dialog modal-dialog-centered modal-xl">
        <div className="modal-content">
          <div className="modal-header bg-primary text-white">
            <h5 className="modal-title">✏️ Edit Dispatch — Order #{order.order_id}</h5>
            <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
          </div>
          <div className="modal-body" style={{ maxHeight: '70vh', overflowY: 'auto' }}>
            {err && <div className="alert alert-danger py-2 mb-3">{err}</div>}

            {/* Order Info - Read Only */}
            <h6 className="fw-bold text-muted mb-3 text-uppercase small">Order Information</h6>
            <div className="row g-3 mb-4">
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Party</div>
                  <div className="fw-semibold">{order.party_name || '—'}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Product</div>
                  <div className="fw-semibold">{order.product_name || '—'}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Quantity</div>
                  <div className="fw-semibold">{parseFloat(order.order_quantity || 0).toFixed(3)} MT</div>
                </div>
              </div>
            </div>

            {/* Editable Dispatch Form */}
            <h6 className="fw-bold text-muted mb-3 text-uppercase small">Dispatch Details</h6>
            <div className="row g-3 mb-4">
              <div className="col-md-6">
                <label className="form-label fw-semibold">Vehicle Number <span className="text-danger">*</span></label>
                <input type="text" className="form-control" value={form.vehicle_number} onChange={e => set('vehicle_number', e.target.value)} />
              </div>
              <div className="col-md-6">
                <label className="form-label fw-semibold">Driver Name</label>
                <input type="text" className="form-control" value={form.driver_name} onChange={e => set('driver_name', e.target.value)} placeholder="Driver name" />
              </div>
              <div className="col-md-6">
                <label className="form-label fw-semibold">Driver Phone <span className="text-danger">*</span></label>
                <input type="tel" className="form-control" placeholder="10-digit" value={form.driver_phone} onChange={e => set('driver_phone', e.target.value.replace(/[^0-9]/g, '').slice(0, 10))} title="Driver phone must be exactly 10 digits (0-9 only)" />
              </div>
              <div className="col-md-6">
                <label className="form-label fw-semibold">Bilty Number <span className="text-danger">*</span></label>
                <input type="text" className="form-control" value={form.bilty_number} onChange={e => set('bilty_number', e.target.value)} />
              </div>
              <div className="col-md-6">
                <label className="form-label fw-semibold">Actual Loading Location <span className="text-danger">*</span></label>
                <select className="form-select" value={form.actual_loading_location_code} onChange={e => set('actual_loading_location_code', e.target.value)}>
                  <option value="">-- Select --</option>
                  {loadingLocations.map(l => <option key={l.code} value={l.code}>{l.code_desc || l.code}</option>)}
                </select>
              </div>
              <div className="col-12">
                <label className="form-label fw-semibold">Comments</label>
                <textarea className="form-control" rows="2" value={form.dispatch_comments} onChange={e => set('dispatch_comments', e.target.value)} placeholder="Add any dispatch comments..." />
              </div>
            </div>

            {/* Receipt Section */}
            <h6 className="fw-bold text-muted mb-3 text-uppercase small">📸 Receipt Photo</h6>
            <div className="mb-4 p-3 border rounded" style={{ background: '#f9f9f9' }}>
              {currentReceiptUrl && !uploadedImageUrl ? (
                <>
                  <img src={currentReceiptUrl} alt="Receipt" style={{maxWidth: '100%', maxHeight: '250px', borderRadius: '8px', marginBottom: '12px'}} />
                  <div className="d-flex gap-2 flex-column flex-sm-row">
                    <button type="button" className="btn btn-sm btn-outline-primary flex-grow-1" onClick={() => handleDownloadReceipt(currentReceiptUrl)}>
                      📥 Download
                    </button>
                    <button type="button" className="btn btn-sm btn-outline-secondary flex-grow-1" onClick={() => galleryInputRef.current?.click()} disabled={uploading}>
                      🔄 Replace
                    </button>
                    <button type="button" className="btn btn-sm btn-outline-danger flex-grow-1" onClick={handleDeleteCurrentReceipt}>
                      🗑️ Delete
                    </button>
                  </div>
                </>
              ) : uploadedImageUrl ? (
                <>
                  <img src={uploadedImageUrl} alt="Uploaded" style={{maxWidth: '100%', maxHeight: '250px', borderRadius: '8px', marginBottom: '12px'}} />
                  <div className="text-muted small mb-3">New receipt ready to save</div>
                  <div className="d-flex gap-2 flex-column flex-sm-row">
                    <button type="button" className="btn btn-sm btn-outline-primary flex-grow-1" onClick={() => handleDownloadReceipt(uploadedImageUrl)}>
                      📥 Download
                    </button>
                    <button type="button" className="btn btn-sm btn-outline-secondary flex-grow-1" onClick={() => { setUploadedImageUrl(null); setSelectedFile(null); setImagePreview(null); }}>
                      ❌ Cancel Upload
                    </button>
                  </div>
                </>
              ) : !selectedFile ? (
                <div className="d-flex gap-2 flex-column flex-sm-row">
                  <button type="button" className="btn btn-sm btn-outline-secondary flex-grow-1" onClick={() => galleryInputRef.current?.click()} disabled={uploading}>
                    📁 Choose from Gallery
                  </button>
                  <button type="button" className="btn btn-sm btn-outline-secondary flex-grow-1" onClick={() => cameraInputRef.current?.click()} disabled={uploading}>
                    📷 Take a Photo
                  </button>
                </div>
              ) : (
                <>
                  <div className="text-muted small mb-2">Selected: {selectedFile.name}</div>
                  <button type="button" className="btn btn-sm btn-primary" onClick={uploadReceipt} disabled={uploading}>
                    {uploading ? `Uploading ${uploadProgress}%...` : 'Upload Receipt'}
                  </button>
                  <button type="button" className="btn btn-sm btn-outline-secondary ms-2" onClick={() => { setSelectedFile(null); setImagePreview(null); }}>
                    Cancel
                  </button>
                </>
              )}
              <input ref={galleryInputRef} type="file" accept="image/*" onChange={handleFileSelect} style={{ display: 'none' }} />
              <input ref={cameraInputRef} type="file" accept="image/*" capture="environment" onChange={handleFileSelect} style={{ display: 'none' }} />
            </div>

            {/* Old Receipt Info Display */}
            {d?.image_url && (
              <div className="mt-4 p-3 bg-light rounded">
                <div className="text-muted small mb-2 fw-semibold">Current Receipt Info</div>
                {d.image_type && <div className="text-muted small">Type: {d.image_type}</div>}
                {d.image_original_size && <div className="text-muted small">Size: {(d.image_original_size / 1024).toFixed(1)} KB</div>}
              </div>
            )}
          </div>

          <div className="modal-footer">
            <button className="btn btn-secondary" onClick={onClose} disabled={saving}>Cancel</button>
            <button className="btn btn-primary" onClick={submit} disabled={saving}>
              {saving ? 'Saving...' : 'Save Dispatch Details'}
            </button>
          </div>
        </div>
      </div>
    </div>
  );
}

// Placeholder for old code that should be removed - marking for cleanup

function CreateForDealerModal({ onClose, onSaved, repeatFrom }) {
  const [dealers, setDealers] = useState([]);
  const [products, setProducts] = useState([]);
  const [parties, setParties] = useState([]);
  const [loadTypes, setLoadTypes] = useState([]);
  const [prefLocations, setPrefLocations] = useState([]);
  const [selectedDealerId, setSelectedDealerId] = useState('');
  const [items, setItems] = useState([{ product_id: '', order_bags: '' }]);
  const [partyId, setPartyId] = useState('');
  const [contactNumber, setContactNumber] = useState('');
  const [deliveryAddress, setDeliveryAddress] = useState('');
  const [loadType, setLoadType] = useState('');
  const [prefLocation, setPrefLocation] = useState('');
  const [driverName, setDriverName] = useState('');
  const [driverPhone, setDriverPhone] = useState('');
  const [vehicleNumber, setVehicleNumber] = useState('');
  const [saving, setSaving] = useState(false);
  const [error, setError] = useState('');

  useEffect(() => {
    Promise.all([
      fetch('/api/dealers', { credentials: 'include' }).then(r => r.json()),
      fetch('/api/dealer/products', { credentials: 'include' }).then(r => r.json()),
      fetch('/api/codes/loading_type', { credentials: 'include' }).then(r => r.json()),
      fetch('/api/codes/loading_location', { credentials: 'include' }).then(r => r.json())
    ]).then(([d, p, lt, pl]) => {
      setDealers(d);
      setProducts(p);
      setLoadTypes(lt || []);
      setPrefLocations(pl || []);
    }).catch(e => console.error(e));
  }, []);

  useEffect(() => {
    if (!repeatFrom || dealers.length === 0) return;
    setSelectedDealerId(String(repeatFrom.dealer_id));
    fetch(`/api/admin/parties/${repeatFrom.dealer_id}`, { credentials: 'include' })
      .then(r => r.json())
      .then(p => {
        setParties(Array.isArray(p) ? p : []);
        if (repeatFrom.party_id) {
          setPartyId(String(repeatFrom.party_id));
          const found = p.find(x => x.party_id === repeatFrom.party_id);
          if (found) {
            setContactNumber(validatePhone(found.party_phone || ''));
            setDeliveryAddress(found.party_address || '');
          }
        }
      });
    if (repeatFrom.items && repeatFrom.items.length > 0) {
      setItems(repeatFrom.items.map(i => ({
        product_id: String(i.product_id),
        order_bags: String(i.order_bags || '')
      })));
    }
    setLoadType(repeatFrom.load_type_code || '');
    setPrefLocation(repeatFrom.preferred_location_code || '');
    if (repeatFrom.load_type_code === 'SLF_DOT') {
      setDriverName(repeatFrom.driver_name_on_order || '');
      setDriverPhone(validatePhone(repeatFrom.driver_phone_on_order || ''));
      setVehicleNumber(repeatFrom.vehicle_number_on_order || '');
    }
  }, [repeatFrom, dealers]);

  const handleDealerChange = async (e) => {
    const dealerId = e.target.value;
    setSelectedDealerId(dealerId);
    if (dealerId) {
      try {
        const r = await fetch(`/api/admin/parties/${dealerId}`, { credentials: 'include' });
        if (!r.ok) {
          const err = await r.json();
          console.error('Failed to load parties:', err.error || err);
          setParties([]);
          return;
        }
        const p = await r.json();
        setParties(Array.isArray(p) ? p : []);
        setPartyId('');
        setContactNumber('');
        setDeliveryAddress('');
      } catch (err) {
        console.error('Failed to load parties:', err);
        setParties([]);
      }
    } else {
      setParties([]);
    }
  };

  const handlePartyChange = (e) => {
    const pId = e.target.value;
    setPartyId(pId);
    const selected = parties.find(p => String(p.party_id) === pId);
    if (selected) {
      setContactNumber(validatePhone(selected.party_phone || ''));
      setDeliveryAddress(selected.party_address || '');
    } else {
      setContactNumber('');
      setDeliveryAddress('');
    }
  };

  const updateItem = (idx, field, value) => {
    const newItems = [...items];
    newItems[idx][field] = value;
    setItems(newItems);
  };

  const removeItem = (idx) => {
    if (items.length > 1) {
      setItems(items.filter((_, i) => i !== idx));
    }
  };

  const addItem = () => {
    setItems([...items, { product_id: '', order_bags: '' }]);
  };

  const calculateQuantity = (bags) => {
    if (!bags) return 0;
    return parseFloat(((parseInt(bags) * 50) / 1000).toFixed(3));
  };

  const totalQty = items.reduce((sum, i) => sum + calculateQuantity(i.order_bags), 0);

  const submit = async (e) => {
    e.preventDefault();
    if (!selectedDealerId) {
      setError('Please select a dealer');
      return;
    }
    if (items.some(i => !i.product_id || !i.order_bags)) {
      setError('All products must have a value for bags');
      return;
    }
    if (!loadType) {
      setError('Loading Type is required');
      return;
    }

    // Find the selected load type to check if it's Company Transport
    const selectedLoadType = loadTypes.find(lt => lt.code === loadType);
    const label = selectedLoadType ? (selectedLoadType.code_label || selectedLoadType.code_desc || '').toUpperCase() : '';
    const isCompanyTransport = label.includes('COMPANY') && label.includes('TRANSPORT');

    if (!isCompanyTransport && !prefLocation) {
      setError('Preferred Loading Location is required for this loading type');
      return;
    }

    setSaving(true); setError('');
    try {
      const res = await fetch('/api/admin/orders/on-behalf', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          items,
          dealer_id: parseInt(selectedDealerId),
          party_id: partyId ? parseInt(partyId) : null,
          load_type_code: loadType || null,
          preferred_location_code: prefLocation || null,
          driver_name: driverName.trim() || null,
          driver_phone: driverPhone.trim() || null,
          vehicle_number: vehicleNumber.trim() || null
        })
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || 'Failed to place order');

      // Fetch complete order details to display in list
      const fullOrderRes = await fetch(`/api/dealer/orders/${data.order_id}`, { credentials: 'include' });
      const fullOrder = await fullOrderRes.json();
      onSaved(fullOrder);
      onClose();
    } catch (err) {
      setError(err.message);
    } finally {
      setSaving(false);
    }
  };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">
          <form onSubmit={submit}>
            <div className="modal-header bg-primary text-white">
              <h5 className="modal-title">{repeatFrom ? `🔁 Repeat Order #${repeatFrom.order_id}` : '🛒 Create Order on Dealer\'s Behalf'}</h5>
              <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
            </div>
            <div className="modal-body">
              {error && <div className="alert alert-danger py-2">{error}</div>}

              {/* Dealer Selection */}
              <div className="mb-3">
                <label className="form-label fw-semibold">Dealer <span className="text-danger">*</span></label>
                <select className="form-select" value={selectedDealerId} onChange={handleDealerChange} required>
                  <option value="">Select a dealer...</option>
                  {dealers.map(d => <option key={d.dealer_id} value={d.dealer_id}>{d.dealer_name} ({d.dealer_code})</option>)}
                </select>
              </div>

              {/* Products Section */}
              <div className="mb-3">
                <label className="form-label fw-semibold">Products &amp; Quantities <span className="text-danger">*</span></label>
                <div className="table-responsive">
                  <table className="table table-sm table-bordered mb-0">
                    <thead className="table-light">
                      <tr>
                        <th>Product</th>
                        <th style={{ width: 100 }}>No. of Bags</th>
                        <th style={{ width: 100 }}>Qty (MT)</th>
                        <th style={{ width: 50, textAlign: 'center' }}>Action</th>
                      </tr>
                    </thead>
                    <tbody>
                      {items.map((item, idx) => (
                        <tr key={idx}>
                          <td>
                            <select
                              className="form-select form-select-sm"
                              value={item.product_id}
                              onChange={(e) => updateItem(idx, 'product_id', e.target.value)}
                              required>
                              <option value="">Select product...</option>
                              {products.map(p => <option key={p.product_id} value={p.product_id}>{p.product_name}</option>)}
                            </select>
                          </td>
                          <td>
                            <input
                              type="number"
                              min="1"
                              className="form-control form-control-sm"
                              value={item.order_bags}
                              onChange={(e) => updateItem(idx, 'order_bags', e.target.value)}
                              placeholder="0"
                              required />
                          </td>
                          <td className="align-middle fw-semibold">
                            {calculateQuantity(item.order_bags).toFixed(3)} MT
                          </td>
                          <td className="text-center align-middle">
                            <button
                              type="button"
                              className="btn btn-sm btn-outline-danger"
                              onClick={() => removeItem(idx)}
                              disabled={items.length === 1}>
                              ✕
                            </button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                    {items.length > 0 && (
                      <tfoot>
                        <tr className="table-secondary fw-bold">
                          <td colSpan={2} className="text-muted small">Total</td>
                          <td>{totalQty.toFixed(3)} MT</td>
                          <td></td>
                        </tr>
                      </tfoot>
                    )}
                  </table>
                </div>
                <button type="button" className="btn btn-sm btn-outline-primary mt-2" onClick={addItem}>
                  ➕ Add Product
                </button>
              </div>

              {/* Ship to Party */}
              <div className="mb-3">
                <label className="form-label fw-semibold">Ship to Party</label>
                <select className="form-select" value={partyId} onChange={handlePartyChange}>
                  <option value="">Select party...</option>
                  {parties.map(p => <option key={p.party_id} value={p.party_id}>{p.party_company_name}</option>)}
                </select>
              </div>

              {/* Contact Number */}
              <div className="mb-3">
                <label className="form-label fw-semibold">Contact Number <span className="text-muted fw-normal small">(10 digits only)</span></label>
                <input
                  type="tel"
                  className="form-control"
                  value={contactNumber}
                  onChange={(e) => setContactNumber(validatePhone(e.target.value))}
                  placeholder="10-digit number"
                  maxLength="10"
                  pattern="[0-9]{10}"
                  title="Contact number must be exactly 10 digits (0-9 only)"
                />
              </div>

              {/* Delivery Address */}
              <div className="mb-3">
                <label className="form-label fw-semibold">Delivery Address</label>
                <textarea
                  className="form-control"
                  rows="2"
                  value={deliveryAddress}
                  onChange={(e) => setDeliveryAddress(e.target.value)}
                  placeholder="Auto-filled or enter manually"
                ></textarea>
              </div>

              {/* Loading Type & Preferred Loading Location */}
              <div className="row g-3 mb-3">
                <div className="col-md-6">
                  <label className="form-label fw-semibold">
                    Loading Type <span className="text-danger">*</span>
                  </label>
                  <select className="form-select" value={loadType} onChange={(e) => {
                    setLoadType(e.target.value);
                    if (e.target.value !== 'SLF_DOT') {
                      setDriverName('');
                      setDriverPhone('');
                      setVehicleNumber('');
                    }
                  }}>
                    <option value="">Select Loading Type</option>
                    {loadTypes.map(lt => <option key={lt.code} value={lt.code}>{lt.code_label || lt.code_desc}</option>)}
                  </select>
                </div>
                <div className="col-md-6">
                  <label className="form-label fw-semibold">
                    Preferred Loading Location
                    {(() => {
                      const selectedLoadType = loadTypes.find(lt => lt.code === loadType);
                      const label = selectedLoadType ? (selectedLoadType.code_label || selectedLoadType.code_desc || '').toUpperCase() : '';
                      const isCompanyTransport = label.includes('COMPANY') && label.includes('TRANSPORT');
                      return !isCompanyTransport && loadType ? <span className="text-danger">*</span> : null;
                    })()}
                  </label>
                  <select className="form-select" value={prefLocation} onChange={(e) => setPrefLocation(e.target.value)}>
                    <option value="">Select Preferred Location</option>
                    {prefLocations.map(pl => <option key={pl.code} value={pl.code}>{pl.code_desc || pl.code_label}</option>)}
                  </select>
                </div>
              </div>

              {/* Self DOT Driver Details (shown only when Self DOT selected) */}
              {loadType === 'SLF_DOT' && (
                <div className="mb-3 p-3 border rounded" style={{ background: '#f0f8ff', borderColor: '#b0d4f1' }}>
                  <div className="fw-semibold small text-primary mb-3">🚛 Self DOT — Driver Details</div>
                  <div className="row g-3">
                    <div className="col-md-4">
                      <label className="form-label fw-semibold small">Driver Name</label>
                      <input type="text" className="form-control" placeholder="e.g. Ramesh Kumar"
                        value={driverName} onChange={e => setDriverName(e.target.value)} />
                    </div>
                    <div className="col-md-4">
                      <label className="form-label fw-semibold small">Driver Phone <span className="text-muted fw-normal">(10 digits only)</span></label>
                      <input type="tel" className="form-control" placeholder="10-digit number"
                        value={driverPhone} onChange={e => setDriverPhone(validatePhone(e.target.value))} maxLength="10" pattern="[0-9]{10}" title="Driver phone must be exactly 10 digits (0-9 only)" />
                    </div>
                    <div className="col-md-4">
                      <label className="form-label fw-semibold small">Vehicle Number</label>
                      <input type="text" className="form-control" placeholder="e.g. MH12AB1234"
                        value={vehicleNumber} onChange={e => setVehicleNumber(e.target.value)} />
                    </div>
                  </div>
                </div>
              )}
            </div>
            <div className="modal-footer">
              <button type="button" className="btn btn-secondary" onClick={onClose}>Cancel</button>
              <button type="submit" className="btn btn-primary" disabled={saving || items.some(i => !i.product_id || !i.order_bags)}>
                {saving && <span className="spinner-border spinner-border-sm me-1"></span>}
                Create Order
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  );
}

// Drill-down modals for admin/office
function StatusDealersModal({ orders, status, onSelectDealer, onClose }) {
  const statusOrders = status === 'TOTAL' ? orders : orders.filter(o => o.order_status === status);
  const dealerMap = {};

  statusOrders.forEach(o => {
    if (!dealerMap[o.dealer_id]) {
      dealerMap[o.dealer_id] = {
        dealer_id: o.dealer_id,
        dealer_name: o.dealer_name,
        count: 0,
      };
    }
    dealerMap[o.dealer_id].count++;
  });

  const dealers = Object.values(dealerMap).sort((a, b) => b.count - a.count);
  const statusConfig = STATUS_CONFIG[status] || { text: status, bg: '#6c757d', icon: '📊' };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.55)' }}>
      <div className="modal-dialog modal-dialog-centered">
        <div className="modal-content">
          <div className="modal-header" style={{ background: statusConfig.bg, color: statusConfig.tc }}>
            <h5 className="modal-title">{statusConfig.icon} {statusConfig.text || 'Total'} Orders by Dealer</h5>
            <button type="button" className="btn-close" style={{filter: 'brightness(0) invert(1)'}} onClick={onClose}></button>
          </div>
          <div className="modal-body" style={{ maxHeight: '70vh', overflowY: 'auto' }}>
            {dealers.length === 0 ? (
              <p className="text-muted text-center py-3">No orders found</p>
            ) : (
              <div className="list-group">
                {dealers.map(dealer => (
                  <button
                    key={dealer.dealer_id}
                    type="button"
                    className="list-group-item list-group-item-action"
                    onClick={() => onSelectDealer(dealer.dealer_id)}
                  >
                    <div className="d-flex justify-content-between align-items-start">
                      <div className="text-start">
                        <div className="fw-semibold">{dealer.dealer_name}</div>
                      </div>
                      <span className="badge bg-info">{dealer.count}</span>
                    </div>
                  </button>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}

function StatusOrdersModal({ orders, status, dealerId, onClose, onBack, onViewOrder }) {
  const statusOrders = status === 'TOTAL'
    ? orders.filter(o => o.dealer_id === dealerId)
    : orders.filter(o => o.dealer_id === dealerId && o.order_status === status);

  const dealerName = statusOrders[0]?.dealer_name || `Dealer #${dealerId}`;
  const statusConfig = STATUS_CONFIG[status] || { text: status, bg: '#6c757d', icon: '📊' };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.55)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">
          <div className="modal-header d-flex align-items-center justify-content-between" style={{ background: statusConfig.bg, color: statusConfig.tc }}>
            <div className="d-flex align-items-center gap-2">
              {onBack && (
                <button type="button" className="btn btn-sm btn-light" onClick={onBack} title="Go back to dealers">
                  ← Back
                </button>
              )}
              <h5 className="modal-title mb-0">{statusConfig.icon} {statusConfig.text || 'Total'} — {dealerName}</h5>
            </div>
            <button type="button" className="btn-close" style={{filter: 'brightness(0) invert(1)'}} onClick={onClose}></button>
          </div>
          <div className="modal-body" style={{ maxHeight: '70vh', overflowY: 'auto' }}>
            {statusOrders.length === 0 ? (
              <p className="text-muted text-center py-3">No orders found</p>
            ) : (
              <div className="space-y-3">
                {statusOrders.map(o => (
                  <div key={o.order_id} className="border rounded p-3" style={{ background: '#f8f9fa' }}>
                    <div className="d-flex justify-content-between align-items-start mb-2">
                      <div>
                        <div className="fw-semibold">Order #{o.order_id}</div>
                        <small className="text-muted">{formatDateTime(o.order_date)}</small>
                      </div>
                      <StatusBadge status={o.order_status} />
                    </div>
                    <div className="row g-2 small mb-2">
                      <div className="col-6">
                        <div className="text-muted">Product</div>
                        <div>{o.product_name || '—'}</div>
                      </div>
                      <div className="col-6">
                        <div className="text-muted">Party</div>
                        <div>{o.party_name || '—'}</div>
                      </div>
                    </div>
                    <button className="btn btn-sm btn-outline-primary" onClick={() => onViewOrder(o)}>
                      👁️ View
                    </button>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}

function App() {
  const getDefaultDates = () => {
    if (CAN_VIEW_ALL) return { start: '', end: '' };
    const end = new Date();
    const start = new Date();
    start.setDate(start.getDate() - 2);
    return {
      start: start.toISOString().slice(0, 10),
      end: end.toISOString().slice(0, 10),
    };
  };
  const defaults = getDefaultDates();

  const [orders, setOrders] = useState([]);
  const [loading, setLoading] = useState(true);
  const [search, setSearch] = useState('');
  const [dealerFilter, setDealerFilter] = useState('');
  const [statusFilter, setStatusFilter] = useState('ALL');
  const [startDate, setStartDate] = useState(defaults.start);
  const [endDate, setEndDate] = useState(defaults.end);
  const [showOnHold, setShowOnHold] = useState(true);
  const [showDispatched, setShowDispatched] = useState(true);
  const [selectedOrder, setSelectedOrder] = useState(null);
  const [viewOrder, setViewOrder] = useState(null);
  const [holdOrder, setHoldOrder] = useState(null);
  const [toast, setToast] = useState({ msg: '', type: 'success' });
  const [sortCol, setSortCol] = useState('order_id');
  const [sortDir, setSortDir] = useState('desc');
  const [dealerLimit, setDealerLimit] = useState(null);
  const [showCreateForDealer, setShowCreateForDealer] = useState(false);
  const [showColumnPicker, setShowColumnPicker] = useState(false);
  const [visibleCols, setVisibleCols] = useState({
    dealer: IS_ADMIN_OR_OFFICE,
    product: true,
    qty: true,
    party: true,
    loadType: true,
    prefLocation: true,
    orderDate: true,
    status: true,
    dispatch: false,
    driverPhone: false,
    biltyNumber: false,
  });

  const [showDispatchDetails, setShowDispatchDetails] = useState(false);
  const [repeatOrder, setRepeatOrder] = useState(null);
  const [refreshing, setRefreshing] = useState(false);
  const esRef = useRef(null);
  const retryRef = useRef(null);

  // Drill-down state for count cards (admin/office only)
  const [selectedStatusForDrilldown, setSelectedStatusForDrilldown] = useState(null);
  const [showStatusDealers, setShowStatusDealers] = useState(false);
  const [selectedStatusDealerId, setSelectedStatusDealerId] = useState(null);

  const toggleSort = (col) => {
    if (sortCol === col) {
      setSortDir(d => d === 'asc' ? 'desc' : 'asc');
    } else {
      setSortCol(col);
      setSortDir('asc');
    }
  };

  const toggleColumn = (col) => {
    setVisibleCols(prev => ({ ...prev, [col]: !prev[col] }));
  };

  const SortTh = ({ col, children, style }) => {
    const active = sortCol === col;
    return (
      <th style={{ cursor: 'pointer', userSelect: 'none', whiteSpace: 'nowrap', ...style }}
          onClick={() => toggleSort(col)}>
        {children}&nbsp;
        <span style={{ opacity: active ? 1 : 0.3, fontSize: '0.75em' }}>
          {active ? (sortDir === 'asc' ? '▲' : '▼') : '▲▼'}
        </span>
      </th>
    );
  };

  const notify = (msg, type = 'success') => {
    setToast({ msg, type });
    setTimeout(() => setToast({ msg: '' }), 4000);
  };

  const load = async (dateFilters = {}) => {
    setLoading(true);
    try {
      const params = new URLSearchParams();
      const effectiveStartDate = dateFilters.startDate ?? startDate;
      const effectiveEndDate = dateFilters.endDate ?? endDate;
      if (effectiveStartDate) params.set('startDate', effectiveStartDate);
      if (effectiveEndDate) params.set('endDate', effectiveEndDate);
      const endpoint = CAN_VIEW_ALL ? '/api/admin/orders' : '/api/dealer/orders';
      const r = await fetch(params.toString() ? `${endpoint}?${params.toString()}` : endpoint, { credentials: 'include' });
      if (!r.ok) throw new Error(await r.text());
      setOrders(await r.json());
    } catch (e) {
      notify(e.message, 'danger');
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    load();
    if (!IS_ADMIN_OR_OFFICE) {
      fetch('/api/dealer/limit', { credentials: 'include' })
        .then(r => r.json())
        .then(data => setDealerLimit(data))
        .catch(err => console.error('Failed to load limit:', err));
    }
  }, []);

  // SSE listener for real-time order status updates
  useEffect(() => {
    function connect() {
      const es = new EventSource('/api/orders/events', { withCredentials: true });
      esRef.current = es;
      es.addEventListener('order-status-changed', () => {
        setRefreshing(true);
        load().finally(() => setRefreshing(false));
      });
      es.onerror = () => {
        es.close();
        esRef.current = null;
        retryRef.current = setTimeout(connect, 3000);
      };
    }
    connect();
    return () => { esRef.current?.close(); clearTimeout(retryRef.current); };
  }, []);

  // ── Load repeat order from URL parameter ────────────────────────────────
  useEffect(() => {
    const params = new URLSearchParams(window.location.search);
    const repeatId = params.get('repeat');
    if (repeatId && orders.length > 0) {
      const foundOrder = orders.find(o => o.order_id == repeatId);
      if (foundOrder) {
        // Validate phone numbers in the order data before setting
        const validatedOrder = {
          ...foundOrder,
          party_phone: validatePhone(foundOrder.party_phone || ''),
          driver_phone_on_order: validatePhone(foundOrder.driver_phone_on_order || ''),
        };
        setRepeatOrder(validatedOrder);
      }
    }
  }, [orders]);

  const applyDateFilter = () => {
    if (startDate && endDate && startDate > endDate) {
      notify('Start Date cannot be later than End Date.', 'danger');
      return;
    }
    load();
  };

  const resetDateFilter = () => {
    const d = getDefaultDates();
    setStartDate(d.start);
    setEndDate(d.end);
    setSearch('');
    setStatusFilter('ALL');
    setDealerFilter('');
    // Use a callback to load after state updates
    Promise.resolve().then(() => {
      load();
    });
  };

  const changeStatus = async (orderId, newStatus, extra = {}) => {
    try {
      const res = await fetch(`/api/dealer/orders/${orderId}/status`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ status: newStatus, ...extra })
      });
      const d = await res.json();
      if (!res.ok) throw new Error(d.error);
      notify(`Order #${orderId} → ${STATUS_CONFIG[newStatus]?.text}`);
      load();
    } catch(e) { notify(e.message, 'danger'); }
  };

  const handleDealerHold = async (reason) => {
    await changeStatus(holdOrder.order_id, 'ON_HOLD', { reason });
    setHoldOrder(null);
  };

  const cancelOrder = async (orderId, reason = '') => {
    if (!window.confirm('Are you sure you want to cancel this order? This action cannot be undone.')) return;
    try {
      const res = await fetch(`/api/orders/${orderId}/cancel`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({ cancellation_reason: reason })
      });
      const d = await res.json();
      if (!res.ok) throw new Error(d.error);
      notify(`Order #${orderId} cancelled`);
      load();
    } catch(e) { notify(e.message, 'danger'); }
  };

  const counts = {
    total:       orders.length,
    orderPlaced: orders.filter(o => o.order_status === 'ORDER_PLACED').length,
    onHold:      orders.filter(o => o.order_status === 'ON_HOLD').length,
    dispatched:  orders.filter(o => ['PARTIALLY_DISPATCHED', 'DISPATCH_ON_HOLD', 'FULLY_DISPATCHED'].includes(o.order_status)).length,
  };

  const filtered = orders.filter(o => {
    const matchSearch = !search || (o.product_name + ' ' + (o.dealer_name || '') + ' ' + o.delivery_location + ' ' + o.order_id + ' ' + (o.party_name || ''))
      .toLowerCase().includes(search.toLowerCase());
    const matchDealer = !dealerFilter || (o.dealer_name && o.dealer_name.toLowerCase().includes(dealerFilter.toLowerCase())) || o.dealer_id === parseInt(dealerFilter);
    const matchStatus = statusFilter === 'ALL' || o.order_status === statusFilter;
    // When toggle is OFF, filter OUT that category. When ON, show that category.
    const matchOnHold = showOnHold || o.order_status !== 'ON_HOLD';
    const isDispatchStatus = ['PARTIALLY_DISPATCHED', 'FULLY_DISPATCHED', 'DISPATCH_ON_HOLD'].includes(o.order_status);
    const matchDispatched = showDispatched || !isDispatchStatus;
    return matchSearch && matchDealer && matchStatus && matchOnHold && matchDispatched;
  });

  const sorted = [...filtered].sort((a, b) => {
    let av = a[sortCol] ?? '';
    let bv = b[sortCol] ?? '';
    // numeric sort for order_id and quantity
    if (sortCol === 'order_id' || sortCol === 'quantity') {
      av = Number(av); bv = Number(bv);
      return sortDir === 'asc' ? av - bv : bv - av;
    }
    // date sort for order_date
    if (sortCol === 'order_date') {
      av = new Date(av); bv = new Date(bv);
      return sortDir === 'asc' ? av - bv : bv - av;
    }
    // string sort
    av = av.toString().toLowerCase(); bv = bv.toString().toLowerCase();
    if (av < bv) return sortDir === 'asc' ? -1 : 1;
    if (av > bv) return sortDir === 'asc' ?  1 : -1;
    return 0;
  });

  const onOrderPlaced = (newOrder) => {
    setOrders(prev => [newOrder, ...prev]);
    notify(`Order #${newOrder.order_id} placed successfully!`);
  };

  const exportExcel = () => {
    const data = [];
    filtered.forEach(o => {
      // Use order_status directly (now contains dispatch status too)
      const realStatus = o.order_status.toLowerCase();

      // If order has items, export each item as a separate row
      if (o.items && o.items.length > 0) {
        o.items.forEach(item => {
          data.push({
            'Order Id': o.order_id,
            'Dealer Name': o.dealer_name || '',
            'Dealer Company Name': o.dealer_company_name || '',
            'Product': item.product_name || '',
            'Status': realStatus,
            'Order Date': formatDateTime(o.order_date),
            'Order Bags': item.order_bags || '',
            'Order Qty': item.order_quantity || '',
            'Dispatch Date': o.dispatch_created_at ? formatDateTime(o.dispatch_created_at) : '',
            'Dispatch Bags': item.order_dispatch_bags || '',
            'Dispatch Qty': item.order_dispatch_quantity || '',
            'Dispatch Notes': item.order_dispatch_comments || '',
            'Delivery Location': o.delivery_location || '',
            'Vehicle No': o.dispatch_vehicle_number || '',
            'Driver Name': o.dispatch_driver_name || '',
            'Driver Phone': o.dispatch_driver_phone || '',
            'Bilty No': o.bilty_number || '',
            'Remarks': o.remarks || '',
            'Party': o.party_name || '',
            'Address': o.party_address || '',
            'Load Type': o.load_type_desc || '',
            'Preferred Location': o.preferred_location_desc || '',
            'Actual Location': o.actual_loading_location_code || '',
          });
        });
      } else {
        // Fallback for orders without items
        data.push({
          'Order Id': o.order_id,
          'Dealer Name': o.dealer_name || '',
          'Dealer Company Name': o.dealer_company_name || '',
          'Product': o.product_name || '',
          'Status': realStatus,
          'Order Date': formatDateTime(o.order_date),
          'Order Bags': o.order_bags || '',
          'Order Qty': `${o.quantity} ${o.unit}`,
          'Dispatch Date': o.dispatch_created_at ? formatDateTime(o.dispatch_created_at) : '',
          'Dispatch Bags': o.order_dispatch_bags || '',
          'Dispatch Qty': o.order_dispatch_quantity || '',
          'Dispatch Notes': o.order_dispatch_comments || '',
          'Delivery Location': o.delivery_location || '',
          'Vehicle No': o.dispatch_vehicle_number || '',
          'Driver Name': o.dispatch_driver_name || '',
          'Driver Phone': o.dispatch_driver_phone || '',
          'Bilty No': o.bilty_number || '',
          'Remarks': o.remarks || '',
          'Party': o.party_name || '',
          'Address': o.party_address || '',
          'Load Type': o.load_type_desc || '',
          'Preferred Location': o.preferred_location_desc || '',
          'Actual Location': o.actual_loading_location_code || '',
        });
      }
    });
    const ws = XLSX.utils.json_to_sheet(data);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, IS_ADMIN_OR_OFFICE ? 'All Orders' : 'My Orders');
    XLSX.writeFile(wb, IS_ADMIN_OR_OFFICE ? 'All_Orders_Dispatch.xlsx' : 'My_Orders.xlsx');
  };

  return (
    <div>
      {refreshing && (
        <div style={{
          position: 'fixed', top: 0, left: 0, right: 0, zIndex: 9999,
          backgroundColor: '#0d6efd', color: '#fff',
          textAlign: 'center', padding: '4px 0',
          fontSize: '0.85rem', fontWeight: 500
        }}>
          Refreshing orders...
        </div>
      )}
      {toast.msg && (
        <div className={`alert alert-${toast.type} alert-dismissible mb-3`}>
          {toast.msg}
          <button className="btn-close" onClick={() => setToast({ msg: '' })}></button>
        </div>
      )}

      {/* Status Dealers Modal (drill-down) */}
      {IS_ADMIN_OR_OFFICE && showStatusDealers && selectedStatusForDrilldown && (
        <StatusDealersModal
          orders={orders}
          status={selectedStatusForDrilldown}
          onSelectDealer={dealerId => {
            setSelectedStatusDealerId(dealerId);
            setShowStatusDealers(false);
          }}
          onClose={() => setShowStatusDealers(false)}
        />
      )}

      {/* Status Orders Modal (drill-down) */}
      {IS_ADMIN_OR_OFFICE && selectedStatusDealerId && selectedStatusForDrilldown && (
        <StatusOrdersModal
          orders={orders}
          status={selectedStatusForDrilldown}
          dealerId={selectedStatusDealerId}
          onClose={() => setSelectedStatusDealerId(null)}
          onBack={() => {
            setSelectedStatusDealerId(null);
            setShowStatusDealers(true);
          }}
          onViewOrder={order => {
            setSelectedOrder(order);
            setSelectedStatusDealerId(null);
          }}
        />
      )}

      {/* Summary Cards */}
      <div className="row mb-2">
        <SummaryCard
          label="Total Orders"
          value={counts.total}
          icon="📋"
          borderColor="#0d6efd"
          isDisabled={!IS_ADMIN_OR_OFFICE || counts.total === 0}
          onClick={() => IS_ADMIN_OR_OFFICE && counts.total > 0 && (setSelectedStatusForDrilldown('TOTAL'), setShowStatusDealers(true))}
        />
        <SummaryCard
          label="Order Placed"
          value={counts.orderPlaced}
          icon="🕐"
          borderColor="#fd7e14"
          isDisabled={!IS_ADMIN_OR_OFFICE || counts.orderPlaced === 0}
          onClick={() => IS_ADMIN_OR_OFFICE && counts.orderPlaced > 0 && (setSelectedStatusForDrilldown('ORDER_PLACED'), setShowStatusDealers(true))}
        />
        <SummaryCard
          label="On Hold"
          value={counts.onHold}
          icon="⏸️"
          borderColor="#e57373"
          isDisabled={!IS_ADMIN_OR_OFFICE || counts.onHold === 0}
          onClick={() => IS_ADMIN_OR_OFFICE && counts.onHold > 0 && (setSelectedStatusForDrilldown('ON_HOLD'), setShowStatusDealers(true))}
        />
        <SummaryCard
          label="Dispatched"
          value={counts.dispatched}
          icon="🚛"
          borderColor="#198754"
          isDisabled={!IS_ADMIN_OR_OFFICE || counts.dispatched === 0}
          onClick={() => IS_ADMIN_OR_OFFICE && counts.dispatched > 0 && (setSelectedStatusForDrilldown('DISPATCHED'), setShowStatusDealers(true))}
        />
        {!IS_ADMIN && dealerLimit && dealerLimit.daily_limit !== null && (
          <div className="col-6 col-md-3 mb-3">
            <div className="card border-0 shadow-sm h-100" style={{ borderLeft: `4px solid ${dealerLimit.daily_limit > 0 && dealerLimit.percentage >= 80 ? '#dc3545' : '#198754'}` }}>
              <div className="card-body p-3">
                <div className="text-muted small mb-2">Daily Remaining</div>
                <div className="fs-5 fw-bold">{dealerLimit.remaining?.toFixed(3) || '—'} MT</div>
                <div className="text-muted small mt-1">
                  {dealerLimit.daily_limit > 0 ? (
                    <>
                      Used: {dealerLimit.used_today?.toFixed(3) || 0} / {dealerLimit.daily_limit?.toFixed(3) || 0} ({dealerLimit.percentage?.toFixed(0) || 0}%)
                    </>
                  ) : (
                    'No limit set'
                  )}
                </div>
                {dealerLimit.percentage >= 80 && dealerLimit.daily_limit > 0 && (
                  <div className="alert alert-danger alert-sm mt-2 mb-0 py-1 px-2" style={{ fontSize: '0.8rem' }}>
                    ⚠️ 80% threshold reached
                  </div>
                )}
                {dealerLimit.admin_phone && (
                  <div className="mt-2 pt-2 border-top">
                    <a
                      href={`tel:${dealerLimit.admin_phone}`}
                      className="btn btn-sm btn-outline-primary w-100"
                      title="Call admin to request limit increase"
                    >
                      📞 Contact Admin
                    </a>
                  </div>
                )}
              </div>
            </div>
          </div>
        )}
      </div>

      {/* Orders Table */}
      <div className="card shadow-sm">
        <div className="card-header bg-white d-flex align-items-center justify-content-between py-2 py-sm-3 flex-wrap gap-2">
          <h5 className="mb-0 fw-semibold">{IS_ADMIN_OR_OFFICE ? '📊 All Orders & Dispatch' : '📋 My Orders'}</h5>
          <div className="d-flex gap-1 gap-sm-2 flex-wrap">
            {IS_ADMIN_OR_OFFICE && (
              <button className={`btn btn-sm ${showDispatchDetails ? 'btn-info' : 'btn-outline-info'}`}
                onClick={() => {setShowDispatchDetails(!showDispatchDetails);setVisibleCols(prev=>({...prev,dispatch:!showDispatchDetails,driverPhone:!showDispatchDetails,biltyNumber:!showDispatchDetails}));}}>
                📦 <span className="d-none d-sm-inline">Dispatch Details</span>
              </button>
            )}
            <div className="dropdown position-relative">
              <button className="btn btn-outline-secondary btn-sm" onClick={() => setShowColumnPicker(!showColumnPicker)}>
                ⚙️ <span className="d-none d-sm-inline">Columns</span>
              </button>
              {showColumnPicker && (
                <div className="dropdown-menu d-block position-absolute" style={{ right: 0, minWidth: 200, zIndex: 1000 }}>
                  <div className="p-2">
                    {IS_ADMIN_OR_OFFICE && (
                      <div className="form-check mb-2">
                        <input className="form-check-input" type="checkbox" id="col-dealer" checked={visibleCols.dealer} onChange={() => toggleColumn('dealer')} />
                        <label className="form-check-label" htmlFor="col-dealer">Dealer</label>
                      </div>
                    )}
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-product" checked={visibleCols.product} onChange={() => toggleColumn('product')} />
                      <label className="form-check-label" htmlFor="col-product">Product</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-qty" checked={visibleCols.qty} onChange={() => toggleColumn('qty')} />
                      <label className="form-check-label" htmlFor="col-qty">Quantity</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-party" checked={visibleCols.party} onChange={() => toggleColumn('party')} />
                      <label className="form-check-label" htmlFor="col-party">Party</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-loadType" checked={visibleCols.loadType} onChange={() => toggleColumn('loadType')} />
                      <label className="form-check-label" htmlFor="col-loadType">Loading Type</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-prefLocation" checked={visibleCols.prefLocation} onChange={() => toggleColumn('prefLocation')} />
                      <label className="form-check-label" htmlFor="col-prefLocation">Pref. Location</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-orderDate" checked={visibleCols.orderDate} onChange={() => toggleColumn('orderDate')} />
                      <label className="form-check-label" htmlFor="col-orderDate">Order Date</label>
                    </div>
                    <div className="form-check mb-2">
                      <input className="form-check-input" type="checkbox" id="col-status" checked={visibleCols.status} onChange={() => toggleColumn('status')} />
                      <label className="form-check-label" htmlFor="col-status">Status</label>
                    </div>
                    <hr className="my-2" />
                    <button className="btn btn-sm btn-outline-primary w-100" onClick={() => setShowColumnPicker(false)}>Close</button>
                  </div>
                </div>
              )}
            </div>
            {IS_ADMIN_OR_OFFICE && (
              <>
                <button className="btn btn-outline-success btn-sm" onClick={exportExcel}>
                  ⬇️ <span className="d-none d-sm-inline">Download</span>
                </button>
                <button className="btn btn-info btn-sm" onClick={() => setShowCreateForDealer(true)}>
                  🛒 <span className="d-none d-sm-inline">Create</span>
                </button>
              </>
            )}
            {!IS_ADMIN_OR_OFFICE && (
              <a className="btn btn-primary btn-sm" href="/orders?action=new">
                🛒 <span className="d-none d-sm-inline">Place New</span>
              </a>
            )}
          </div>
        </div>
        {/* Filters */}
        <div className="d-flex align-items-center gap-3 mb-3 flex-wrap p-3 bg-white rounded shadow-sm">
          <span className="fw-bold text-muted small text-uppercase">Filters:</span>
          <div className="d-flex gap-2 align-items-center">
            <label className="small text-muted mb-0">From:</label>
            <input type="date" className="form-control form-control-sm" style={{width: '120px'}}
              value={startDate} onChange={e => setStartDate(e.target.value)} />
            <label className="small text-muted mb-0">To:</label>
            <input type="date" className="form-control form-control-sm" style={{width: '120px'}}
              value={endDate} onChange={e => setEndDate(e.target.value)} />
          </div>
          <div className="form-check form-switch mb-0">
            <input className="form-check-input" type="checkbox" id="toggleOnHold"
              checked={showOnHold} onChange={e => setShowOnHold(e.target.checked)} />
            <label className="form-check-label" htmlFor="toggleOnHold">⏸️ Show On Hold</label>
          </div>
          <div className="form-check form-switch mb-0">
            <input className="form-check-input" type="checkbox" id="toggleDispatched"
              checked={showDispatched} onChange={e => setShowDispatched(e.target.checked)} />
            <label className="form-check-label" htmlFor="toggleDispatched">🚛 Show Dispatched</label>
          </div>
          <div className="ms-auto d-flex gap-2">
            <button className="btn btn-sm btn-outline-success" onClick={exportExcel} disabled={filtered.length === 0}>
              ⬇️ Download
            </button>
            <button className="btn btn-sm btn-outline-primary" onClick={applyDateFilter}>
              🔄 Refresh
            </button>
          </div>
        </div>

        {/* Search */}
        <div className="mb-4">
          <input className="form-control form-control-sm" placeholder="Search by product, party, dealer, address, order ID…"
            value={search} onChange={e => setSearch(e.target.value)} />
        </div>

        <div className="card-body">

          {loading ? (
            <div className="text-center py-5">
              <div className="spinner-border text-primary"></div>
              <p className="text-muted mt-2">Loading orders…</p>
            </div>
          ) : (
            <div className="table-responsive">
              <table className="table table-hover table-bordered align-middle mb-0">
                <thead className="table-light">
                  <tr style={{ fontSize: 'clamp(0.75rem, 2vw, 0.875rem)' }}>
                    <SortTh col="order_id" style={{ width: 70, minWidth: 70 }}>Order Id</SortTh>
                    {IS_ADMIN_OR_OFFICE && visibleCols.dealer && <SortTh col="dealer_name" style={{ minWidth: 80 }}>Dealer</SortTh>}
                    {visibleCols.product && <SortTh col="product_name" style={{ minWidth: 80 }}>Product</SortTh>}
                    {visibleCols.qty && <SortTh col="quantity" style={{ width: 70, minWidth: 70 }}>Qty</SortTh>}
                    {visibleCols.party && <SortTh col="party_name" style={{ minWidth: 80 }}>Party</SortTh>}
                    {visibleCols.loadType && <SortTh col="load_type_desc" style={{ minWidth: 80 }}>Load Type</SortTh>}
                    {visibleCols.prefLocation && <SortTh col="preferred_location_desc" style={{ minWidth: 100 }}>Pref. Loc</SortTh>}
                    {visibleCols.orderDate && <SortTh col="order_date" style={{ width: 100, minWidth: 100 }}>Order Date</SortTh>}
                    {visibleCols.status && <th style={{ width: 100, minWidth: 100, textAlign: 'center' }}>Status</th>}
                    {visibleCols.dispatch && <th style={{ width: 80, minWidth: 80, textAlign: 'center' }}>Dispatch</th>}
                    {visibleCols.driverPhone && <th style={{ width: 100, minWidth: 100, textAlign: 'center' }}>Driver Phone</th>}
                    {visibleCols.biltyNumber && <th style={{ width: 90, minWidth: 90, textAlign: 'center' }}>Bilty No.</th>}
                    <th style={{ width: 140, minWidth: 140, textAlign: 'center' }}>Action</th>
                  </tr>
                </thead>
                <tbody>
                  {sorted.length === 0 ? (
                    <tr><td colSpan={Object.values(visibleCols).filter(Boolean).length + (IS_ADMIN_OR_OFFICE ? 2 : 1)} className="text-center text-muted py-4">No orders found</td></tr>
                  ) : sorted.map(o => (
                    <tr key={o.order_id}>
                      <td className="fw-semibold text-primary">#{o.order_id}</td>
                      {IS_ADMIN_OR_OFFICE && visibleCols.dealer && <td className="text-muted small">{o.dealer_name || '—'}</td>}
                      {visibleCols.product && <td>{o.product_name}</td>}
                      {visibleCols.qty && <td>{o.quantity} {o.unit}</td>}
                      {visibleCols.party && <td>{o.party_name || <span className="text-muted">—</span>}</td>}
                      {visibleCols.loadType && <td>{o.load_type_desc || <span className="text-muted">—</span>}</td>}
                      {visibleCols.prefLocation && <td>{o.preferred_location_desc || <span className="text-muted">—</span>}</td>}
                      {visibleCols.orderDate && <td>{formatDateTime(o.order_date)}</td>}
                      {visibleCols.status && <td className="text-center">
                        <div>
                          <StatusBadge status={o.order_status} />
                          {o.order_status === 'ON_HOLD' && o.on_hold_reason && (
                            <div className="text-muted small mt-2" style={{ fontSize: '0.75rem', maxWidth: 150, margin: '0 auto' }}>
                              💬 {o.on_hold_reason}
                            </div>
                          )}
                        </div>
                      </td>}
                      {visibleCols.dispatch && <td className="text-center">
                        {o.dispatch ? (
                          <div>
                            <span className="text-success small fw-semibold">
                              🚛 {o.dispatch.vehicle_no}
                            </span>
                            {o.dispatch?.image_url && (
                              <div className="mt-1">
                                <span className="badge bg-info small">📸 Receipt</span>
                              </div>
                            )}
                          </div>
                        ) : (
                          <span className="text-muted small">—</span>
                        )}
                      </td>}
                      {visibleCols.driverPhone && <td className="text-center">
                        {o.dispatch?.driver_phone ? (
                          <a href={`tel:${o.dispatch.driver_phone}`} className="text-decoration-none fw-semibold">
                            ☎️ {o.dispatch.driver_phone}
                          </a>
                        ) : (
                          <span className="text-muted small">—</span>
                        )}
                      </td>}
                      {visibleCols.biltyNumber && <td className="text-center">
                        {o.dispatch?.bilty_number ? (
                          <span className="fw-semibold">{o.dispatch.bilty_number}</span>
                        ) : (
                          <span className="text-muted small">—</span>
                        )}
                      </td>}
                      <td className="text-nowrap" style={{ fontSize: '0.85rem' }}>
                        <div style={{ display: 'flex', flexWrap: 'wrap', gap: '0.25rem' }}>
                          {/* View Button */}
                          <button className="btn btn-sm btn-outline-primary me-1" onClick={() => setViewOrder(o)}>
                            👁️ View
                          </button>

                          {/* Hold on ORDER_PLACED */}
                          {o.order_status === 'ORDER_PLACED' && (
                            <button className="btn btn-sm btn-outline-secondary me-1" onClick={() => setHoldOrder(o)}>
                              ⏸️ Hold
                            </button>
                          )}

                          {/* Edit on ORDER_PLACED */}
                          {o.order_status === 'ORDER_PLACED' && (
                            <button className="btn btn-sm btn-outline-info me-1" onClick={() => {
                              const editUrl = CAN_VIEW_ALL && !IS_ADMIN_OR_OFFICE
                                ? `/admin/dealer-orders?action=edit&id=${o.order_id}`
                                : `/orders?action=edit&id=${o.order_id}`;
                              window.location.href = editUrl;
                            }}>
                              ✏️ Edit
                            </button>
                          )}

                          {/* Unhold on ON_HOLD */}
                          {o.order_status === 'ON_HOLD' && (
                            <button className="btn btn-sm btn-outline-warning me-1" onClick={() => changeStatus(o.order_id, 'ORDER_PLACED')}>
                              ⏸️ Unhold
                            </button>
                          )}

                          {/* Admin: Accept on ORDER_PLACED */}
                          {IS_ADMIN && o.order_status === 'ORDER_PLACED' && (
                            <button className="btn btn-sm btn-outline-info me-1" onClick={() => changeStatus(o.order_id, 'ACCEPTED')}>
                              ✅ Accept
                            </button>
                          )}

                          {/* Admin: Hold on ORDER_PLACED */}
                          {IS_ADMIN && o.order_status === 'ORDER_PLACED' && (
                            <button className="btn btn-sm btn-outline-secondary me-1" onClick={() => setHoldOrder(o)}>
                              ⏸️ Hold
                            </button>
                          )}

                          {/* Admin/Office/Dispatcher: Edit Dispatch only on DISPATCH_ON_HOLD or PARTIALLY_DISPATCHED */}
                          {(IS_ADMIN_OR_OFFICE || IS_DISPATCHER) && ['DISPATCH_ON_HOLD', 'PARTIALLY_DISPATCHED'].includes(o.order_status) && (
                            <button className="btn btn-sm btn-warning me-1" onClick={() => setSelectedOrder(o)}>
                              ✏️ Edit Dispatch
                            </button>
                          )}

                          {/* Admin/Office: Unhold on ON_HOLD (admin/office held) */}
                          {IS_ADMIN_OR_OFFICE && o.order_status === 'ON_HOLD' && o.on_hold_by_role !== 'DEALER' && (
                            <button className="btn btn-sm btn-outline-warning me-1" onClick={() => changeStatus(o.order_id, 'ORDER_PLACED')}>
                              ⏸️ Unhold
                            </button>
                          )}

                          {/* Hold Badge for Admin/Office held orders */}
                          {IS_ADMIN_OR_OFFICE && o.order_status === 'ON_HOLD' && o.on_hold_by_role === 'DEALER' && (
                            <span className="badge bg-secondary" style={{ lineHeight: '1.5' }}>🔒 Hold</span>
                          )}

                          {/* Locked Badge for dealer on ACCEPTED */}
                          {!IS_ADMIN && o.order_status === 'ACCEPTED' && (
                            <span className="badge bg-secondary" style={{ lineHeight: '1.5' }}>🔒 Locked</span>
                          )}

                          {/* Repeat Button - Dealer or Admin viewing dealer orders */}
                          {!IS_ADMIN_OR_OFFICE && !CAN_VIEW_ALL && (
                            <a className="btn btn-sm btn-outline-primary me-1" href={`/orders?action=new&repeat=${o.order_id}`}>
                              🔁 Repeat
                            </a>
                          )}

                          {/* Repeat Button - Admin/Office or Admin viewing dealer orders */}
                          {(IS_ADMIN_OR_OFFICE || (CAN_VIEW_ALL && !IS_ADMIN_OR_OFFICE)) && (
                            <button className="btn btn-sm btn-outline-primary me-1" onClick={() => setRepeatOrder(o)}>
                              🔁 Repeat
                            </button>
                          )}
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
      </div>

      {viewOrder && <ViewOrderModal order={viewOrder} onClose={() => setViewOrder(null)} />}
      {selectedOrder && <DispatchModal order={selectedOrder} onClose={() => setSelectedOrder(null)} onRefresh={load} />}
      {showCreateForDealer && <CreateForDealerModal onClose={() => setShowCreateForDealer(false)} onSaved={onOrderPlaced} />}
      {repeatOrder && <CreateForDealerModal repeatFrom={repeatOrder} onClose={() => setRepeatOrder(null)} onSaved={onOrderPlaced} />}
      {holdOrder && <OnHoldModal order={holdOrder} onConfirm={handleDealerHold} onClose={() => setHoldOrder(null)} requireReason={IS_ADMIN_OR_OFFICE} />}
    </div>
  );
}

ReactDOM.createRoot(document.getElementById('app-root')).render(<App />);
</script>
<%- include('../partials/footer') %>
