<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
    <title>ODTS — Order Dispatch &amp; Tracking System</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script>
      function showTrackingUnavailable() {
        alert('Live Tracking is currently unavailable. Real-time tracking capabilities feature will be available soon.');
      }
    </script>
  </head>
  <body>

    <nav class="navbar navbar-expand-lg odts-navbar">
      <div class="container">
        <!-- Brand -->
        <a class="navbar-brand" href="/">
          <div class="brand-icon">🚚</div>
          <span>ODTS</span>
        </a>

        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>

        <div class="collapse navbar-collapse" id="mainNav">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0 gap-1">
            <% if (typeof user !== 'undefined' && user) { %>
            <li class="nav-item">
              <a class="nav-link" href="/dashboard">🏠 Dashboard</a>
            </li>
            <% } %>

            <% if (typeof user !== 'undefined' && user && user.role === 'DEALER') { %>
            <li class="nav-item">
              <a class="nav-link" href="javascript:void(0)" onclick="showTrackingUnavailable()">📡 Live Tracking</a>
            </li>
            <% } %>

            <% if (typeof user !== 'undefined' && user && user.role === 'DEALER') { %>
            <li class="nav-item">
              <a class="nav-link" href="/orders">📋 My Orders</a>
            </li>
            <% } %>

            <% if (typeof user !== 'undefined' && user && user.role === 'DISPATCHER') { %>
            <li class="nav-item">
              <a class="nav-link" href="/dispatcher">🚛 Dispatch Dashboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="javascript:void(0)" onclick="showTrackingUnavailable()">📡 Live Tracking</a>
            </li>
            <% } %>

            <% if (typeof user !== 'undefined' && user && user.role === 'OFFICE_EXECUTIVE') { %>
            <li class="nav-item">
              <a class="nav-link" href="/office/dashboard">📊 Office Dashboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/master/products">📦 Products</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/master/dealers">🏢 Dealers</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/master/code-reference">📍 Locations</a>
            </li>
            <% } %>

            <% if (typeof user !== 'undefined' && user && user.role === 'SALES_OFFICER') { %>
            <li class="nav-item">
              <a class="nav-link" href="/sales/dashboard">📊 Sales Dashboard</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/sales/report">📈 Sales Report</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="javascript:void(0)" onclick="showTrackingUnavailable()">📡 Live Tracking</a>
            </li>
            <% } %>

            <% if (typeof user !== 'undefined' && user && user.role === 'ADMIN') { %>
            <li class="nav-item">
              <a class="nav-link" href="/notifications">📱 WhatsApp Notifications</a>
            </li>
            <li class="nav-item dropdown">
              <a class="nav-link dropdown-toggle" href="#" id="masterMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                🗂️ Master Data
              </a>
              <ul class="dropdown-menu shadow" aria-labelledby="masterMenu">
                <li><a class="dropdown-item" href="/admin/reports">📈 Reports</a></li>
                <li><a class="dropdown-item" href="/sales/report">📈 Sales Report</a></li>
                <li><a class="dropdown-item" href="/master/products">📦 Products</a></li>
                <li><a class="dropdown-item" href="/master/dealers">🏢 Dealers</a></li>
                <li><a class="dropdown-item" href="/master/warehouse">🏭 Warehouse</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="/master/code-reference">⚙️ Configuration</a></li>
                <li><a class="dropdown-item" href="/master/users">👥 Login Users</a></li>
                <li><a class="dropdown-item" href="/master/user-roles">🔑 User Roles</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item" href="/admin/sessions">🔐 Sessions &amp; Audit</a></li>
              </ul>
            </li>
            <% } %>
          </ul>

          <!-- Right: user info -->
          <ul class="navbar-nav ms-auto user-pill">
            <% if (typeof user !== 'undefined' && user && (user.role === 'ADMIN' || user.role === 'OFFICE_EXECUTIVE')) { %>
            <li class="nav-item me-1 d-flex align-items-center dropdown">
              <button id="notif-btn" class="btn position-relative p-2"
                style="background:none; border:none; color:inherit;"
                data-bs-toggle="dropdown" data-bs-auto-close="true" aria-expanded="false"
                title="Quota Alerts">
                🔔
                <span id="notif-badge"
                  class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger"
                  style="display:none; font-size:0.65rem;"></span>
              </button>
              <div class="dropdown-menu dropdown-menu-end p-0 shadow"
                style="min-width:320px; max-width:360px;">
                <div class="d-flex align-items-center justify-content-between px-3 py-2 border-bottom bg-light rounded-top">
                  <span class="fw-semibold small">⚠️ Monthly Quota Alerts</span>
                  <span id="notif-month" class="text-muted" style="font-size:0.75rem;"></span>
                </div>
                <div id="notif-list" style="max-height:360px; overflow-y:auto;">
                  <div class="text-center text-muted py-3 small">Loading…</div>
                </div>
              </div>
            </li>
            <% } %>
            <% if (typeof user !== 'undefined' && user) { %>
              <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown" aria-expanded="false" title="Session timeout: <%= sessionTimeoutHours %>h">
                  👤 <%= user.user_login_name || user.username %> &nbsp;<span class="badge-role"><%= user.role %></span>
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow">
                  <li><span class="dropdown-item-text text-muted small"><%= user.user_login_name || user.username %></span></li>
                  <li><span class="dropdown-item-text text-muted small">⏱️ Auto logout after <%= sessionTimeoutHours %> hours of inactivity</span></li>
                  <li><hr class="dropdown-divider my-1"></li>
                  <li><a class="dropdown-item" href="#" onclick="openChangePasswordModal(event)">🔐 Change Password</a></li>
                  <li><a class="dropdown-item text-danger fw-600" href="/logout">🚪 Sign out</a></li>
                </ul>
              </li>
            <% } else { %>
              <li class="nav-item"><a class="nav-link" href="/signin">Sign In</a></li>
            <% } %>
          </ul>
        </div>
      </div>
    </nav>

    <!-- Change Password Modal -->
    <div class="modal fade" id="changePasswordModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">🔐 Change Password</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div id="changePasswordAlert" class="alert" style="display:none;"></div>
            <form id="changePasswordForm">
              <div class="mb-3">
                <label for="currentPassword" class="form-label fw-semibold">Current Password <span class="text-danger">*</span></label>
                <div class="password-input-group">
                  <input type="password" class="form-control password-field" id="currentPassword" name="currentPassword" required>
                  <button type="button" class="btn-password-toggle" onclick="togglePassword(this)">
                    <span class="password-icon">👁️</span>
                  </button>
                </div>
              </div>
              <div class="mb-3">
                <label for="newPassword" class="form-label fw-semibold">New Password <span class="text-danger">*</span></label>
                <div class="password-input-group">
                  <input type="password" class="form-control password-field" id="newPassword" name="newPassword" required>
                  <button type="button" class="btn-password-toggle" onclick="togglePassword(this)">
                    <span class="password-icon">👁️</span>
                  </button>
                </div>
                <small class="text-muted d-block mt-1">Minimum 6 characters</small>
              </div>
              <div class="mb-3">
                <label for="confirmPassword" class="form-label fw-semibold">Confirm New Password <span class="text-danger">*</span></label>
                <div class="password-input-group">
                  <input type="password" class="form-control password-field" id="confirmPassword" name="confirmPassword" required>
                  <button type="button" class="btn-password-toggle" onclick="togglePassword(this)">
                    <span class="password-icon">👁️</span>
                  </button>
                </div>
              </div>
            </form>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
            <button type="button" class="btn btn-primary" id="changePasswordBtn" onclick="submitChangePassword()">
              <span id="changePasswordBtnText">Change Password</span>
              <span id="changePasswordBtnSpinner" class="spinner-border spinner-border-sm ms-2" style="display:none;"></span>
            </button>
          </div>
        </div>
      </div>
    </div>

    <script>
      function togglePassword(btn) {
        const input = btn.closest('.password-input-group').querySelector('.password-field');
        const icon = btn.querySelector('.password-icon');
        if (input.type === 'password') {
          input.type = 'text';
          icon.textContent = '🙈';
        } else {
          input.type = 'password';
          icon.textContent = '👁️';
        }
      }

      function openChangePasswordModal(event) {
        event.preventDefault();
        document.getElementById('changePasswordForm').reset();
        document.getElementById('changePasswordAlert').style.display = 'none';
        // Reset all password fields to type="password" and icons to eye
        document.querySelectorAll('#changePasswordModal .password-field').forEach(field => {
          field.type = 'password';
        });
        document.querySelectorAll('#changePasswordModal .password-icon').forEach(icon => {
          icon.textContent = '👁️';
        });
        const modal = new bootstrap.Modal(document.getElementById('changePasswordModal'));
        modal.show();
      }

      async function submitChangePassword() {
        const currentPassword = document.getElementById('currentPassword').value.trim();
        const newPassword = document.getElementById('newPassword').value.trim();
        const confirmPassword = document.getElementById('confirmPassword').value.trim();
        const alertEl = document.getElementById('changePasswordAlert');

        // Validation
        if (!currentPassword || !newPassword || !confirmPassword) {
          alertEl.className = 'alert alert-warning';
          alertEl.textContent = 'All fields are required';
          alertEl.style.display = 'block';
          return;
        }

        if (newPassword.length < 6) {
          alertEl.className = 'alert alert-warning';
          alertEl.textContent = 'New password must be at least 6 characters';
          alertEl.style.display = 'block';
          return;
        }

        if (newPassword !== confirmPassword) {
          alertEl.className = 'alert alert-warning';
          alertEl.textContent = 'New passwords do not match';
          alertEl.style.display = 'block';
          return;
        }

        if (currentPassword === newPassword) {
          alertEl.className = 'alert alert-warning';
          alertEl.textContent = 'New password must be different from current password';
          alertEl.style.display = 'block';
          return;
        }

        // Submit
        const btn = document.getElementById('changePasswordBtn');
        const spinner = document.getElementById('changePasswordBtnSpinner');
        const btnText = document.getElementById('changePasswordBtnText');
        btn.disabled = true;
        spinner.style.display = 'inline-block';
        btnText.textContent = 'Changing...';

        try {
          const res = await fetch('/api/change-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
              currentPassword,
              newPassword
            })
          });

          const data = await res.json();

          if (res.ok) {
            alertEl.className = 'alert alert-success';
            alertEl.textContent = '✅ Password changed successfully!';
            alertEl.style.display = 'block';
            setTimeout(() => {
              bootstrap.Modal.getInstance(document.getElementById('changePasswordModal')).hide();
            }, 2000);
          } else {
            alertEl.className = 'alert alert-danger';
            alertEl.textContent = data.error || 'Failed to change password';
            alertEl.style.display = 'block';
          }
        } catch (e) {
          alertEl.className = 'alert alert-danger';
          alertEl.textContent = 'Error: ' + e.message;
          alertEl.style.display = 'block';
        } finally {
          btn.disabled = false;
          spinner.style.display = 'none';
          btnText.textContent = 'Change Password';
        }
      }
    </script>

    <main class="container page-main">
