<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover" />
  <title>Sign In — ODTS</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<div class="signin-wrapper">
  <div class="signin-card">

    <!-- Header -->
    <div class="signin-header">
      <div class="logo-box">🚚</div>
      <h1>Order Dispatch &amp; Tracking System</h1>
      <p>Sign in to your account to continue</p>
    </div>

    <!-- Body -->
    <div class="signin-body">
      <% if (error) { %>
        <div class="alert alert-danger mb-3">
          ⚠️ <%= error %>
        </div>
      <% } %>

      <form method="post" action="/signin">
        <div class="mb-3">
          <label class="form-label">User Name</label>
          <input name="user_login_name" type="text" class="form-control form-control-lg"
            placeholder="Enter your login name" autocomplete="username" required />
        </div>
        <div class="mb-4">
          <label class="form-label">Password</label>
          <div class="password-input-group">
            <input name="password" type="password" class="form-control form-control-lg password-field"
              placeholder="••••••••" autocomplete="current-password" required />
            <button type="button" class="btn-password-toggle" onclick="togglePassword(this)">
              <span class="password-icon">👁️</span>
            </button>
          </div>
        </div>
        <div class="d-grid gap-2">
          <button class="btn btn-primary btn-lg fw-600" type="submit">Sign In →</button>
          <button class="btn btn-outline-secondary" type="reset">Clear</button>
        </div>
      </form>
    </div>

  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script>
  function togglePassword(btn) {
    const input = btn.closest('.password-input-group').querySelector('.password-field');
    const icon = btn.querySelector('.password-icon');
    if (input.type === 'password') {
      input.type = 'text';
      icon.textContent = '🙈';
    } else {
      input.type = 'password';
      icon.textContent = '👁️';
    }
  }
</script>
</body>
</html>
