<script type="text/babel">
const { useState, useEffect, useCallback, useRef } = React;

const STATUS_CONFIG = {
  ORDER_PLACED:          { text: 'Order Placed',           icon: '🕐', bg: '#fd7e14', tc: '#fff' },
  ACCEPTED:              { text: 'Accepted',               icon: '✅', bg: '#0dcaf0', tc: '#000' },
  ON_HOLD:               { text: 'On Hold',                icon: '⏸️', bg: '#e57373', tc: '#fff' },
  FULLY_DISPATCHED:      { text: 'Fully Dispatched',       icon: '✅', bg: '#198754', tc: '#fff' },
  PARTIALLY_DISPATCHED:  { text: 'Partially Dispatched',   icon: '📦', bg: '#fd7e14', tc: '#fff' },
  DISPATCH_ON_HOLD:      { text: 'Dispatch on Hold',       icon: '⏸️', bg: '#e57373', tc: '#fff' },
  CANCELLED:             { text: 'Cancelled',              icon: '❌', bg: '#6c757d', tc: '#fff' },
};

const validatePhone=(val)=>val.replace(/[^0-9]/g,'').slice(0,10);
const isValidPhone=(val)=>/^\d{10}$/.test(val.replace(/[^0-9]/g,''));

function fmt(value) {
  if (!value) return '—';
  const dt = new Date(value);
  if (isNaN(dt.getTime())) return value;
  return new Intl.DateTimeFormat('en-IN', {
    day: '2-digit', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit', hour12: true,
  }).format(dt);
}

function StatusBadge({ status }) {
  const cfg = STATUS_CONFIG[status] || { bg: '#6c757d', tc: '#fff', text: status, icon: '' };
  return (
    <span className="badge" style={{ background: cfg.bg, color: cfg.tc }}>
      {cfg.icon} {cfg.text}
    </span>
  );
}

function Toast({ msg, type, onClose }) {
  useEffect(() => {
    const t = setTimeout(onClose, 4000);
    return () => clearTimeout(t);
  }, []);
  return (
    <div style={{
      position: 'fixed', top: 80, right: 20, zIndex: 9999, minWidth: 280,
      background: type === 'success' ? '#198754' : '#dc3545',
      color: '#fff', padding: '12px 18px', borderRadius: 8,
      boxShadow: '0 4px 16px rgba(0,0,0,.25)'
    }}>
      {type === 'success' ? '✅' : '❌'} {msg}
    </div>
  );
}

// Global handler for downloading receipts
async function handleDownloadReceipt(imageUrl, orderId) {
  try {
    if (!imageUrl) throw new Error('No receipt URL provided');

    console.log('[Download] Starting receipt download:', imageUrl);
    let urlToDownload = imageUrl;

    // If imageUrl doesn't start with http, it's either a local path or S3 key
    if (!imageUrl.startsWith('http')) {
      // Check if it's a local path (starts with /uploads)
      if (imageUrl.startsWith('/uploads')) {
        console.log('[Download] Using local path directly:', imageUrl);
        urlToDownload = imageUrl;
      } else if (imageUrl.startsWith('receipts/')) {
        // Convert S3 key to local path for local storage mode
        console.log('[Download] Converting S3 key to local path:', imageUrl);
        urlToDownload = `/uploads/${imageUrl}`;
      } else {
        // Try generating presigned URL for S3
        console.log('[Download] Generating presigned URL for S3 key:', imageUrl);
        const res = await fetch('/api/dispatcher/presigned-read-url', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ s3Key: imageUrl })
        });

        if (!res.ok) {
          throw new Error('Failed to generate presigned URL');
        }

        const data = await res.json();
        urlToDownload = data.url;
      }
    }

    console.log('[Download] Fetching from:', urlToDownload);
    const response = await fetch(urlToDownload);
    console.log('[Download] Response status:', response.status);

    if (!response.ok) {
      throw new Error(`HTTP ${response.status}: ${response.statusText}`);
    }

    const blob = await response.blob();
    console.log('[Download] Blob size:', blob.size);

    const url = window.URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;

    const timestamp = new Date().toISOString().split('T')[0];
    const ext = urlToDownload.includes('jpeg') || urlToDownload.includes('jpg') ? 'jpg' : 'png';
    link.download = `Receipt_Order${orderId}_${timestamp}.${ext}`;

    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    window.URL.revokeObjectURL(url);

    console.log('[Download] Download completed successfully');
  } catch (error) {
    console.error('[Download] Error:', error);
    alert(`Failed to download receipt: ${error.message}`);
  }
}

function DispatchModal({ order, loadingLocations, onSubmit, onClose, notify, onRefresh }) {
  // isExistingDispatch: order is already in dispatch state (only edit quantities)
  // Includes: DISPATCHED, PARTIALLY_DISPATCHED, DISPATCH_ON_HOLD
  // isInitialDispatch: order not yet dispatched (fill in all dispatch details + quantities)
  const isExistingDispatch = ['PARTIALLY_DISPATCHED', 'DISPATCH_ON_HOLD', 'FULLY_DISPATCHED'].includes(order.order_status) || !!order.dispatch_id;
  const items = parseItems(order);
  const totalOrderBags = items.reduce((s, i) => s + (parseInt(i.order_bags || 0)), 0);
  const totalOrderQty = items.reduce((s, i) => s + parseFloat(i.order_quantity || 0), 0);

  // Initialize form with dispatch quantities for each item
  const initialForm = {
    vehicle_number: order.load_type_code === 'SLF_DOT' ? (order.vehicle_number_on_order || '') : '',
    driver_name: order.load_type_code === 'SLF_DOT' ? (order.driver_name_on_order || '') : '',
    driver_phone: order.load_type_code === 'SLF_DOT' ? (order.driver_phone_on_order || '') : '',
    bilty_number: '',
    actual_loading_location_code: '',
  };

  // Add dispatch quantities and comments for each item
  // Initialize dispatch form with empty values (dispatch data now stored in order_dispatch_items table)
  if (items && items.length > 0) {
    items.forEach((item, idx) => {
      initialForm[`dispatch_bags_${idx}`] = 0;
      initialForm[`dispatch_quantity_${idx}`] = 0;
    });
  } else {
    initialForm['dispatch_bags'] = 0;
    initialForm['dispatch_quantity'] = 0;
  }

  // Overall dispatch comments
  initialForm['dispatch_comments'] = '';

  const [form, setForm] = useState(initialForm);
  const [saving, setSaving] = useState(false);
  const [err, setErr] = useState('');

  // Receipt upload states
  const [selectedFile, setSelectedFile] = useState(null);
  const [imagePreview, setImagePreview] = useState(null);
  const [uploading, setUploading] = useState(false);
  const [uploadProgress, setUploadProgress] = useState(0);
  const [uploadedImageUrl, setUploadedImageUrl] = useState(null);
  const [imageMetadata, setImageMetadata] = useState(null);
  const [skipUploadConfirm, setSkipUploadConfirm] = useState(false);
  const [currentReceiptUrl, setCurrentReceiptUrl] = useState(order.image_url);

  // Dispatch items state
  const [dispatchItems, setDispatchItems] = useState([]);
  const [loadingItems, setLoadingItems] = useState(false);
  const [dispatchItemForm, setDispatchItemForm] = useState({
    product_id: '',
    actual_loading_location_code: '',
    warehouse_available_qty: '',
    dispatch_bags: '',
    dispatch_vehicle_number: '',
    dispatch_driver_name: '',
    dispatch_driver_phone: '',
    dispatch_bilty_number: '',
    dispatch_notes: ''
  });
  const [creatingItem, setCreatingItem] = useState(false);

  const galleryInputRef = useRef(null);
  const cameraInputRef = useRef(null);

  const set = (k, v) => setForm(f => ({ ...f, [k]: v }));

  // Fetch dispatch items when modal opens
  useEffect(() => {
    if (isExistingDispatch) {
      setLoadingItems(true);
      fetch(`/api/orders/${order.order_id}/dispatch-items`, { credentials: 'include' })
        .then(r => r.json())
        .then(data => {
          setDispatchItems(Array.isArray(data) ? data : []);
          setLoadingItems(false);
        })
        .catch(e => {
          console.error('Error loading dispatch items:', e);
          setLoadingItems(false);
        });
    }
  }, [order.order_id, isExistingDispatch]);

  // Fetch warehouse stock when product is selected
  useEffect(() => {
    if (dispatchItemForm.product_id && dispatchItemForm.actual_loading_location_code && isExistingDispatch) {
      // Fetch warehouse stock for the selected product from warehouse_inventory
      // Join warehouse_master (actual_loading_location_code = warehouse_id) with warehouse_inventory by product_id
      fetch(`/api/warehouse-inventory`)
        .then(r => r.json())
        .then(data => {
          const inventoryRecords = Array.isArray(data) ? data : [];
          const warehouseId = parseInt(dispatchItemForm.actual_loading_location_code);
          const productId = parseInt(dispatchItemForm.product_id);

          // Find inventory for selected warehouse and product
          const matchingInventory = inventoryRecords.find(inv =>
            inv.warehouse_id === warehouseId && inv.product_id === productId
          );

          if (matchingInventory && matchingInventory.current_qty > 0) {
            setDispatchItemForm(f => ({
              ...f,
              warehouse_available_qty: matchingInventory.current_qty.toString()
            }));
          } else {
            setDispatchItemForm(f => ({...f, warehouse_available_qty: '0'}));
          }
        })
        .catch(e => {
          console.error('Error fetching warehouse inventory:', e);
          setDispatchItemForm(f => ({...f, warehouse_available_qty: '—'}));
        });
    }
  }, [dispatchItemForm.product_id, dispatchItemForm.actual_loading_location_code, isExistingDispatch]);

  // Handle creating new dispatch item
  const handleCreateDispatchItem = async (e) => {
    e.preventDefault();
    if (!dispatchItemForm.dispatch_bags || !dispatchItemForm.dispatch_vehicle_number || !dispatchItemForm.dispatch_driver_phone || !dispatchItemForm.dispatch_bilty_number) {
      setErr('Please fill in all required fields');
      return;
    }

    // Validate driver phone is exactly 10 digits
    if (dispatchItemForm.dispatch_driver_phone.length !== 10) {
      setErr('❌ Driver phone must be exactly 10 digits');
      return;
    }

    // Validate dispatch quantity against warehouse stock
    const dispatchQty = parseInt(dispatchItemForm.dispatch_bags);
    const availableQty = parseInt(dispatchItemForm.warehouse_available_qty) || 0;

    if (dispatchQty > availableQty) {
      setErr(`❌ Cannot dispatch ${dispatchQty} bags. Only ${availableQty} bags available in warehouse.`);
      return;
    }

    if (availableQty === 0) {
      setErr('❌ No stock available in warehouse for this product.');
      return;
    }

    // Validate dispatch quantity against order quantity for this product
    const selectedProductId = parseInt(dispatchItemForm.product_id);
    const selectedItem = items.find(item => item.product_id === selectedProductId);

    if (!selectedItem) {
      setErr('❌ Selected product not found in order.');
      return;
    }

    const totalOrderBags = parseInt(selectedItem.order_bags || 0);
    const alreadyDispatchedBags = dispatchItems
      .filter(di => di.product_id === selectedProductId)
      .reduce((sum, di) => sum + (parseInt(di.dispatch_bags) || 0), 0);

    const remainingBags = totalOrderBags - alreadyDispatchedBags;

    if (dispatchQty > remainingBags) {
      setErr(`❌ Cannot dispatch ${dispatchQty} bags. Only ${remainingBags} bags remaining for this product (${totalOrderBags} ordered, ${alreadyDispatchedBags} already dispatched).`);
      return;
    }

    if (remainingBags === 0) {
      setErr('❌ All bags for this product have already been dispatched.');
      return;
    }

    setCreatingItem(true);
    try {
      const response = await fetch(`/api/orders/${order.order_id}/dispatch-items`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'include',
        body: JSON.stringify({
          dispatch_bags: parseInt(dispatchItemForm.dispatch_bags),
          dispatch_quantity: parseFloat(dispatchItemForm.dispatch_bags) * 0.05, // Placeholder calculation
          dispatch_vehicle_number: dispatchItemForm.dispatch_vehicle_number,
          dispatch_driver_name: dispatchItemForm.dispatch_driver_name,
          dispatch_driver_phone: dispatchItemForm.dispatch_driver_phone,
          dispatch_bilty_number: dispatchItemForm.dispatch_bilty_number,
          dispatch_notes: dispatchItemForm.dispatch_notes,
          dispatch_receipt_image_url: null,
          product_id: dispatchItemForm.product_id,
          dispatch_warehouse_id: dispatchItemForm.actual_loading_location_code
        })
      });

      if (!response.ok) {
        const data = await response.json();
        throw new Error(data.error || 'Failed to create dispatch item');
      }

      // Reload dispatch items
      const itemsRes = await fetch(`/api/orders/${order.order_id}/dispatch-items`, { credentials: 'include' });
      const items = await itemsRes.json();
      setDispatchItems(Array.isArray(items) ? items : []);

      // Reset form
      setDispatchItemForm({
        product_id: '',
        actual_loading_location_code: '',
        warehouse_available_qty: '',
        dispatch_bags: '',
        dispatch_vehicle_number: '',
        dispatch_driver_name: '',
        dispatch_driver_phone: '',
        dispatch_bilty_number: '',
        dispatch_notes: ''
      });
      notify('Dispatch item created successfully', 'success');
      setErr('');
    } catch (e) {
      setErr(e.message);
      console.error('Error creating dispatch item:', e);
    } finally {
      setCreatingItem(false);
    }
  };

  const handleFileSelect = async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;

    // Validate file type
    const validTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/gif', 'image/webp'];
    if (!validTypes.includes(file.type)) {
      setErr('Please select a valid image file (JPG, PNG, GIF, WebP)');
      return;
    }

    setSelectedFile(file);
    const reader = new FileReader();
    reader.onload = (evt) => setImagePreview(evt.target.result);
    reader.readAsDataURL(file);
    setErr('');
    setSkipUploadConfirm(false);
  };

  const handleDeleteReceipt = () => {
    setUploadedImageUrl(null);
    setImageMetadata(null);
    setSelectedFile(null);
    setImagePreview(null);
    setErr('');
  };

  const handleDeleteCurrentReceipt = async () => {
    if (!confirm('Are you sure you want to delete this receipt?')) {
      return;
    }

    try {
      const res = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch/receipt`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' }
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Failed to delete receipt');
      }

      // Immediately update local state to remove receipt from UI
      setCurrentReceiptUrl(null);
      console.log('Receipt deleted successfully');
    } catch (error) {
      console.error('Delete receipt error:', error);
      setErr(error.message);
    }
  };

  const uploadReceipt = async () => {
    if (!selectedFile) return;

    try {
      setUploading(true);
      setErr('');

      let fileToUpload = selectedFile;
      let compressedSize = null;

      // Compress if file > 500KB
      if (selectedFile.size > 500 * 1024 && typeof window.ImageCompression !== 'undefined') {
        setUploadProgress(10);
        try {
          const options = {
            maxSizeMB: 0.5,
            maxWidthOrHeight: 1920,
            useWebWorker: true,
          };
          fileToUpload = await window.ImageCompression.compress(selectedFile, options);
          compressedSize = fileToUpload.size;
          console.log(`Compressed image: ${selectedFile.size} → ${fileToUpload.size} bytes`);
        } catch (compressError) {
          console.warn('Image compression failed, using original:', compressError.message);
        }
      }

      setUploadProgress(20);

      // Step 1: Request presigned URL from backend
      console.log('Requesting presigned URL from backend...');
      const presignedRes = await fetch('/api/dispatcher/presigned-url', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          order_id: order.order_id,
          dealer_id: order.dealer_id,
          file_name: fileToUpload.name,
          file_type: fileToUpload.type,
        }),
      });

      if (!presignedRes.ok) {
        const errorData = await presignedRes.json().catch(() => ({}));
        throw new Error(errorData.error || `Failed to get presigned URL: ${presignedRes.status}`);
      }

      const { url: presignedUrl, s3Key, isLocal } = await presignedRes.json();
      console.log('Presigned URL received:', s3Key, 'isLocal:', isLocal);
      setUploadProgress(40);

      let s3Url;

      if (isLocal) {
        // Local upload: POST to the upload endpoint
        console.log('Uploading file to local endpoint...');

        // Convert file to base64 using FileReader
        const fileBase64 = await new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => {
            const dataUrl = reader.result;
            const base64 = dataUrl.includes(',') ? dataUrl.split(',')[1] : dataUrl;
            resolve(base64);
          };
          reader.onerror = reject;
          reader.readAsDataURL(fileToUpload);
        });

        const localUploadRes = await fetch(presignedUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            filePath: s3Key,
            fileData: fileBase64,
            order_id: order.order_id,
            dealer_id: order.dealer_id
          })
        });

        if (!localUploadRes.ok) {
          throw new Error(`Local upload failed: ${localUploadRes.status} ${localUploadRes.statusText}`);
        }

        const localResult = await localUploadRes.json();
        s3Url = localResult.image_url;
        console.log('Receipt uploaded locally:', s3Url);

        // For local storage, the URL is already a displayable local path
        // Store this local path in metadata (not an S3 key)
        setUploadProgress(80);
        setUploadProgress(95);
        setUploadedImageUrl(s3Url);
        setImageMetadata({
          image_url: s3Url,
          image_type: fileToUpload.type,
          image_original_size: selectedFile.size,
          image_compressed_size: compressedSize,
        });
      } else {
        // S3 upload: PUT file directly to presigned URL
        console.log('Uploading file directly to S3...');
        const s3UploadRes = await fetch(presignedUrl, {
          method: 'PUT',
          body: fileToUpload,
          headers: { 'Content-Type': fileToUpload.type },
        });

        if (!s3UploadRes.ok) {
          throw new Error(`S3 upload failed: ${s3UploadRes.status} ${s3UploadRes.statusText}`);
        }

        // After successful upload, extract S3 key and generate fresh presigned URL for preview
        console.log('Extracting S3 key from upload URL...');
        const extractedS3Key = presignedUrl.split('/receipts/')[1]?.split('?')[0];
        if (!extractedS3Key) {
          throw new Error('Could not extract S3 key from upload URL');
        }

        const fullS3Key = `receipts/${extractedS3Key}`;
        console.log('S3 key extracted:', fullS3Key);

        // Generate presigned READ URL for preview display
        console.log('Generating presigned read URL for preview...');
        const readUrlRes = await fetch('/api/dispatcher/presigned-read-url', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ s3Key: fullS3Key })
        });

        if (!readUrlRes.ok) {
          throw new Error('Failed to generate read presigned URL');
        }

        const readResult = await readUrlRes.json();
        const previewUrl = readResult.url;
        console.log('Presigned read URL generated for preview');

        setUploadProgress(80);
        setUploadProgress(95);

        // Store metadata: save only S3 key (database), but display fresh presigned URL (preview)
        setUploadedImageUrl(previewUrl);
        setImageMetadata({
          image_url: fullS3Key,
          image_type: fileToUpload.type,
          image_original_size: selectedFile.size,
          image_compressed_size: compressedSize,
        });
      }

      setUploadProgress(100);
      setUploading(false);
    } catch (error) {
      console.error('Upload error:', error);
      setErr(`Upload failed: ${error.message}`);
      setUploading(false);
      setUploadProgress(0);
    }
  };

  const submit = async () => {
    console.log('[DispatchModal] Submit - isExistingDispatch:', isExistingDispatch, 'order_status:', order.order_status, 'dispatch_vehicle_number:', order.dispatch_vehicle_number);

    // Validate dispatch form fields (always required for initial dispatch)
    if (!isExistingDispatch) {
      if (!form.vehicle_number.trim())                return setErr('Vehicle number is required');
      if (!form.driver_phone.trim())                  return setErr('Driver phone is required');
      if (!/^\d{10}$/.test(form.driver_phone.trim())) return setErr('Driver phone must be exactly 10 digits');
      if (!form.bilty_number.trim())                  return setErr('Bilty number is required');
      if (!form.actual_loading_location_code)         return setErr('Actual loading location is required');

      // Check if image is selected but not uploaded
      if (selectedFile && !uploadedImageUrl && !skipUploadConfirm) {
        setSkipUploadConfirm(true);
        return;
      }
    }

    setErr('');
    setSaving(true);

    try {
      if (isExistingDispatch) {
        // Editing existing dispatch: save dispatch quantities, comments, and details
        const dispatchQuantities = items.map((item, idx) => ({
          item_id: item.item_id,
          dispatch_bags: parseInt(form[`dispatch_bags_${idx}`] || 0),
          dispatch_quantity: parseFloat(form[`dispatch_quantity_${idx}`] || 0),
          dispatch_comments: form.dispatch_comments || ''
        }));

        console.log('[Edit Dispatch] Sending to backend:', JSON.stringify(dispatchQuantities, null, 2));

        // Update dispatch record with new details (including new receipt if uploaded)
        const updatePayload = {
          vehicle_number: form.vehicle_number || order.dispatch_vehicle_number,
          driver_name: form.driver_name || order.dispatch_driver_name,
          driver_phone: form.driver_phone || order.dispatch_driver_phone,
          bilty_number: form.bilty_number || order.bilty_number,
          actual_loading_location_code: form.actual_loading_location_code || order.actual_loading_location_code
        };

        // Include new receipt metadata if one was uploaded
        if (imageMetadata) {
          updatePayload.image_url = imageMetadata.image_url;
          updatePayload.image_type = imageMetadata.image_type;
          updatePayload.image_original_size = imageMetadata.image_original_size;
          updatePayload.image_compressed_size = imageMetadata.image_compressed_size;
        }

        const dispatchUpdateRes = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updatePayload)
        });

        if (!dispatchUpdateRes.ok) {
          const err = await dispatchUpdateRes.json();
          throw new Error(err.error || 'Failed to update dispatch details');
        }

        // Update quantities and comments
        const res = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch-quantities`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ dispatchQuantities })
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to update dispatch quantities');

        notify(`✅ Dispatch updated to ${data.order_status} status`);
        setSaving(false);
        onClose();
        // Refresh orders list to show updated status
        if (onRefresh) onRefresh();
      } else {
        // Initial dispatch: create dispatch record AND save dispatch quantities
        const finalForm = { ...form, ...imageMetadata };

        // First, dispatch the order
        const dispatchRes = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(finalForm)
        });

        if (!dispatchRes.ok) {
          const err = await dispatchRes.json();
          throw new Error(err.error || 'Failed to dispatch order');
        }

        // Then save dispatch quantities
        const dispatchQuantities = items.map((item, idx) => ({
          item_id: item.item_id,
          dispatch_bags: parseInt(form[`dispatch_bags_${idx}`] || 0),
          dispatch_quantity: parseFloat(form[`dispatch_quantity_${idx}`] || 0),
          dispatch_comments: form.dispatch_comments || ''
        }));

        const qtyRes = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch-quantities`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ dispatchQuantities })
        });

        if (!qtyRes.ok) {
          const err = await qtyRes.json();
          throw new Error(err.error || 'Failed to save dispatch quantities');
        }

        notify(`✅ Order #${order.order_id} dispatched successfully`);
        onClose();
        // Refresh orders list to show updated status
        if (onRefresh) onRefresh();
      }
    } catch (e) {
      setErr(e.message);
    }
    setSaving(false);
  };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.55)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">

          <div className="modal-header" style={{ background: '#198754', color: '#fff' }}>
            <h5 className="modal-title">
              🚛 Dispatch — Order #{order.order_id}
            </h5>
            <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
          </div>

          <div className="modal-body">
            {/* Section 1: Dealer Orders Information (Non-Editable) */}
            <div className="mb-4 p-3 border rounded" style={{ background: '#f9f9f9', borderColor: '#ddd' }}>
              <h6 className="fw-bold text-primary text-uppercase small mb-3">Dealer Orders (Non-Editable)</h6>

              {/* Order summary */}
              <div className="row g-2 mb-4 p-3 rounded" style={{ background: '#f8faff' }}>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Dealer</div>
                <div className="fw-semibold">{order.dealer_login_name || order.dealer_company_name || order.dealer_name}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Order Time</div>
                <div className="fw-semibold" style={{ fontSize: '.85rem' }}>{fmt(order.order_date)}</div>
              </div>
              {/* Products & Quantities — with dispatch columns in edit mode */}
              <div className="col-12">
                <div className="text-muted small mb-1 fw-semibold">Products &amp; Quantities</div>
                <div style={{ overflowX: 'auto' }}>
                  <table className="table table-sm table-bordered mb-0" style={{ fontSize: '.80rem', background: '#fff', minWidth: '100%' }}>
                    <thead className="table-light">
                      <tr>
                        <th style={{ minWidth: 150 }}>Product</th>
                        <th style={{ width: 70 }}>Bags</th>
                        <th style={{ width: 90 }}>Qty (MT)</th>
                      </tr>
                    </thead>
                    <tbody>
                      {items && items.length > 0 ? (
                        items.map((item, idx) => (
                          <tr key={idx}>
                            <td>{item.product_name || `#${item.product_id}`}</td>
                            <td>{item.order_bags || '—'}</td>
                            <td>{parseFloat(item.order_quantity).toFixed(3)}</td>
                          </tr>
                        ))
                      ) : (
                        <tr>
                          <td>{order.product_name || '—'}</td>
                          <td>—</td>
                          <td>{parseFloat(order.quantity || 0).toFixed(3)}</td>
                        </tr>
                      )}
                    </tbody>
                    {items && items.length > 1 && (
                      <tfoot>
                        <tr className="table-secondary fw-bold">
                          <td colSpan="3" className="text-muted small text-end">Total: {items.reduce((s, i) => s + parseInt(i.order_bags || 0), 0)} bags, {items.reduce((s, i) => s + parseFloat(i.order_quantity || 0), 0).toFixed(3)} MT</td>
                        </tr>
                      </tfoot>
                    )}
                  </table>
                </div>
              </div>

              <div className="col-6 col-md-4">
                <div className="text-muted small">Party</div>
                <div className="fw-semibold">{order.party_company_name || order.party_name_col || '—'}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Delivery Address</div>
                <div className="fw-semibold">{order.party_address || '—'}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Party Phone</div>
                <div className="fw-semibold">
                  {order.party_phone
                    ? <a href={`tel:${order.party_phone}`}>{order.party_phone}</a>
                    : '—'}
                </div>
              </div>
              <div className="col-6 col-md-6">
                <div className="text-muted small">Load Type</div>
                <div className="fw-semibold">{order.load_type_desc || order.load_type_code || '—'}</div>
              </div>
              <div className="col-6 col-md-6">
                <div className="text-muted small">Preferred Loading Location</div>
                <div className="fw-semibold">{order.preferred_location_desc || order.preferred_location_code || '—'}</div>
              </div>
            </div>
            </div>
            {/* End of Dealer Orders Information Section */}

            {/* Dispatch Orders Grid - show at top for existing dispatch */}
            {isExistingDispatch && (
              <div className="mb-4 p-3 border rounded" style={{ background: '#f5f9ff', borderColor: '#b0d4f1' }}>
                <div className="text-muted small mb-3 fw-semibold">🚛 Dispatched orders ({dispatchItems.length})</div>
                <div style={{ maxHeight: '250px', overflowY: 'auto', borderRadius: '4px', border: '1px solid #dee2e6' }}>
                  {loadingItems ? (
                    <div className="text-center text-muted py-3">
                      <span className="spinner-border spinner-border-sm me-2"></span>Loading...
                    </div>
                  ) : dispatchItems.length === 0 ? (
                    <div className="text-center text-muted py-3 small">
                      No dispatch items yet. Add your first dispatch item below.
                    </div>
                  ) : (
                    <table className="table table-sm mb-0">
                      <thead className="table-light" style={{ position: 'sticky', top: 0 }}>
                        <tr>
                          <th style={{ width: '70px' }}>Bags</th>
                          <th style={{ width: '90px' }}>Qty (MT)</th>
                          <th style={{ width: '120px' }}>Driver</th>
                          <th style={{ width: '110px' }}>Vehicle</th>
                          <th style={{ width: '85px' }}>Bilty</th>
                          <th style={{ width: '110px' }}>Date</th>
                        </tr>
                      </thead>
                      <tbody>
                        {dispatchItems.map((item, idx) => (
                          <tr key={idx}>
                            <td className="small">{item.dispatch_bags || '—'}</td>
                            <td className="small">{item.dispatch_quantity ? parseFloat(item.dispatch_quantity).toFixed(3) : '—'}</td>
                            <td className="small" title={item.dispatch_driver_name}>{item.dispatch_driver_name ? item.dispatch_driver_name.substring(0, 12) : '—'}</td>
                            <td className="small">{item.dispatch_vehicle_number || '—'}</td>
                            <td className="small" title={item.dispatch_bilty_number}>{item.dispatch_bilty_number ? item.dispatch_bilty_number.substring(0, 10) : '—'}</td>
                            <td className="small">{item.created_at ? fmt(item.created_at) : '—'}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  )}
                </div>
              </div>
            )}

            {/* Dispatch Orders - Add Dispatch Items */}
            {isExistingDispatch && (
              <div className="mb-4 p-3 border rounded" style={{ background: '#f0f8ff', borderColor: '#b0d4f1' }}>
                <h6 className="fw-bold text-primary text-uppercase small mb-3">Dispatched orders (Editable)</h6>
                <div className="row g-3">
                  {/* Add Dispatch Item Section */}
                  <div className="col-12">
                    <h6 className="fw-bold text-primary text-uppercase small mb-3">➕ Add Dispatch Item</h6>
                    <form onSubmit={handleCreateDispatchItem} style={{ display: 'grid', gridTemplateColumns: '1fr 1fr', gap: '0.75rem' }}>
                      <div>
                        <label className="form-label fw-semibold">Actual Loading Location <span className="text-danger">*</span></label>
                        <select
                          className="form-select"
                          value={dispatchItemForm.actual_loading_location_code || ''}
                          onChange={(e) => setDispatchItemForm({...dispatchItemForm, actual_loading_location_code: e.target.value})}
                          required
                        >
                          <option value="">-- Select Warehouse --</option>
                          {loadingLocations.map(w => (
                            <option key={w.warehouse_id} value={w.warehouse_id}>
                              {w.warehouse_name}
                            </option>
                          ))}
                        </select>
                      </div>
                      <div>
                        <label className="form-label fw-semibold">Product <span className="text-danger">*</span></label>
                        <select
                          className="form-select"
                          value={dispatchItemForm.product_id || ''}
                          onChange={(e) => setDispatchItemForm({...dispatchItemForm, product_id: e.target.value})}
                          required
                        >
                          <option value="">-- Select Product --</option>
                          {items.map(item => (
                            <option key={item.item_id} value={item.product_id}>
                              {item.product_name} (Order: {item.order_bags || item.order_quantity} bags)
                            </option>
                          ))}
                        </select>
                      </div>
                      <div>
                        <label className="form-label fw-semibold">Warehouse Available Qty</label>
                        <input
                          type="text"
                          className="form-control"
                          value={dispatchItemForm.warehouse_available_qty || '—'}
                          disabled
                          style={{ background: '#f0f0f0' }}
                        />
                      </div>
                      <div>
                        <label className="form-label fw-semibold">Dispatch Quantity <span className="text-danger">*</span></label>
                        <input
                          type="number"
                          placeholder="Quantity to dispatch"
                          value={dispatchItemForm.dispatch_bags}
                          onChange={(e) => setDispatchItemForm({...dispatchItemForm, dispatch_bags: e.target.value})}
                          className={`form-control ${parseInt(dispatchItemForm.dispatch_bags) > (parseInt(dispatchItemForm.warehouse_available_qty) || 0) && dispatchItemForm.dispatch_bags ? 'is-invalid' : ''}`}
                          required
                        />
                        {parseInt(dispatchItemForm.dispatch_bags) > (parseInt(dispatchItemForm.warehouse_available_qty) || 0) && dispatchItemForm.dispatch_bags && (
                          <div className="text-danger small mt-1">
                            ⚠️ Cannot dispatch {dispatchItemForm.dispatch_bags} bags. Only {dispatchItemForm.warehouse_available_qty} available.
                          </div>
                        )}
                      </div>
                      <div>
                        <label className="form-label fw-semibold">Vehicle Number <span className="text-danger">*</span></label>
                        <input
                          type="text"
                          placeholder="Vehicle number"
                          value={dispatchItemForm.dispatch_vehicle_number}
                          onChange={(e) => setDispatchItemForm({...dispatchItemForm, dispatch_vehicle_number: e.target.value})}
                          className="form-control"
                          required
                        />
                      </div>
                      <div>
                        <label className="form-label fw-semibold">Driver Name</label>
                        <input
                          type="text"
                          placeholder="Driver name (optional)"
                          value={dispatchItemForm.dispatch_driver_name}
                          onChange={(e) => setDispatchItemForm({...dispatchItemForm, dispatch_driver_name: e.target.value})}
                          className="form-control"
                        />
                      </div>
                      <div>
                        <label className="form-label fw-semibold">Driver Phone (10 digits) <span className="text-danger">*</span></label>
                        <input
                          type="tel"
                          placeholder="10-digit mobile number"
                          value={dispatchItemForm.dispatch_driver_phone}
                          onChange={(e) => setDispatchItemForm({...dispatchItemForm, dispatch_driver_phone: validatePhone(e.target.value)})}
                          className={`form-control ${dispatchItemForm.dispatch_driver_phone && dispatchItemForm.dispatch_driver_phone.length !== 10 ? 'is-invalid' : ''}`}
                          required
                          maxLength="10"
                        />
                        {dispatchItemForm.dispatch_driver_phone && dispatchItemForm.dispatch_driver_phone.length !== 10 && (
                          <small className="text-danger d-block mt-1">⚠️ Must be exactly 10 digits</small>
                        )}
                      </div>
                      <div>
                        <label className="form-label fw-semibold">Bilty Number <span className="text-danger">*</span></label>
                        <input
                          type="text"
                          placeholder="Bilty/transport number"
                          value={dispatchItemForm.dispatch_bilty_number}
                          onChange={(e) => setDispatchItemForm({...dispatchItemForm, dispatch_bilty_number: e.target.value})}
                          className="form-control"
                          required
                        />
                      </div>
                      <div>
                        <label className="form-label fw-semibold">Dispatch Comments</label>
                        <input
                          type="text"
                          placeholder="Comments (optional)"
                          value={dispatchItemForm.dispatch_notes}
                          onChange={(e) => setDispatchItemForm({...dispatchItemForm, dispatch_notes: e.target.value})}
                          className="form-control"
                        />
                      </div>
                      <div style={{ gridColumn: '1 / -1' }}>
                        <label className="form-label fw-semibold">📸 Receipt Photo (Optional)</label>
                        <div className="d-flex gap-2">
                          <button
                            type="button"
                            className="btn btn-outline-secondary btn-sm flex-grow-1"
                            onClick={() => galleryInputRef.current?.click()}
                            disabled={creatingItem}
                          >
                            📁 Choose from Gallery
                          </button>
                          <button
                            type="button"
                            className="btn btn-outline-secondary btn-sm flex-grow-1"
                            onClick={() => cameraInputRef.current?.click()}
                            disabled={creatingItem}
                          >
                            📷 Take a Photo
                          </button>
                        </div>
                        <small className="text-muted d-block mt-2">Auto-compressed to ~500 KB if larger</small>
                      </div>
                      <button
                        type="submit"
                        disabled={creatingItem}
                        className="btn btn-primary"
                        style={{ gridColumn: '1 / -1' }}
                      >
                        {creatingItem ? (
                          <><span className="spinner-border spinner-border-sm me-1"></span>Creating...</>
                        ) : (
                          '✅ Add Dispatch Items'
                        )}
                      </button>
                    </form>
                  </div>
                </div>
              </div>
            )}

            {/* Dispatch form - only show for initial dispatch */}
            {!isExistingDispatch && (
              <>
                <h6 className="fw-bold text-muted text-uppercase small mb-3">Enter Dispatch Details</h6>
                {err && !skipUploadConfirm && <div className="alert alert-danger py-2 mb-3">{err}</div>}

                <div className="row g-3">
                  <div className="col-md-6">
                    <label className="form-label fw-semibold">
                      Vehicle Number <span className="text-danger">*</span>
                    </label>
                    <input
                      className="form-control text-uppercase"
                      placeholder="e.g. UP32AB1234"
                      value={form.vehicle_number}
                      onChange={e => set('vehicle_number', e.target.value.toUpperCase())}
                    />
                  </div>
                  <div className="col-md-6">
                    <label className="form-label fw-semibold">
                      Bilty Number <span className="text-danger">*</span>
                    </label>
                    <input
                      className="form-control"
                      placeholder="Transport receipt / bilty number"
                      value={form.bilty_number}
                      onChange={e => set('bilty_number', e.target.value)}
                    />
                  </div>
                  <div className="col-md-6">
                    <label className="form-label fw-semibold">Driver Name</label>
                    <input
                      className="form-control"
                      placeholder="Driver full name (optional)"
                      value={form.driver_name}
                      onChange={e => set('driver_name', e.target.value)}
                    />
                  </div>
                  <div className="col-md-6">
                    <label className="form-label fw-semibold">
                      Driver Phone <span className="text-danger">*</span> <span className="text-muted fw-normal small">(10 digits only)</span>
                    </label>
                    <input
                      type="tel"
                      className={`form-control ${form.driver_phone && form.driver_phone.length !== 10 ? 'is-invalid' : ''}`}
                      placeholder="10-digit mobile number"
                      value={form.driver_phone}
                      onChange={e => set('driver_phone', validatePhone(e.target.value))}
                      pattern="[0-9]{10}"
                      title="Driver phone must be exactly 10 digits (0-9 only)"
                      maxLength="10"
                    />
                    {form.driver_phone && form.driver_phone.length !== 10 && (
                      <small className="text-danger d-block mt-1">⚠️ Must be exactly 10 digits</small>
                    )}
                  </div>
                  <div className="col-12">
                    <label className="form-label fw-semibold">
                      Actual Loading Location <span className="text-danger">*</span>
                    </label>
                    <select
                      className="form-select"
                      value={form.actual_loading_location_code}
                      onChange={e => set('actual_loading_location_code', e.target.value)}
                    >
                      <option value="">-- Select Warehouse --</option>
                      {loadingLocations.map(w => (
                        <option key={w.warehouse_id} value={w.warehouse_id}>
                          {w.warehouse_name}
                        </option>
                      ))}
                    </select>
                  </div>
                </div>
              </>
            )}
            {isExistingDispatch && err && <div className="alert alert-danger py-2 mb-3">{err}</div>}
          </div>

          <div className="modal-footer">
            <button className="btn btn-secondary" onClick={onClose}>Cancel</button>
            <button className="btn btn-success" disabled={saving} onClick={submit}>
              {saving && <span className="spinner-border spinner-border-sm me-1"></span>}
              {isExistingDispatch ? '💾 Save Changes' : '🚛 Confirm Dispatch'}
            </button>
          </div>

        </div>
      </div>
    </div>
  );
}

function parseItems(order) {
  const raw = order.items;
  if (!raw) return [];
  const arr = typeof raw === 'string' ? JSON.parse(raw) : raw;
  return Array.isArray(arr) ? arr.filter(i => i && i.product_id) : [];
}

function ItemsCell({ order }) {
  const items = parseItems(order);
  if (items.length === 0) return <span className="text-muted">—</span>;
  if (items.length === 1) return <span>{items[0].product_name || `#${items[0].product_id}`}</span>;
  return (
    <span>
      {items[0].product_name || `#${items[0].product_id}`}
      <span className="badge bg-secondary ms-1" style={{ fontSize: '.7rem' }}>+{items.length - 1}</span>
    </span>
  );
}

function QtyCell({ order }) {
  const items = parseItems(order);
  const total = items.reduce((s, i) => s + parseFloat(i.order_quantity || 0), 0);
  const display = total > 0 ? total : parseFloat(order.order_quantity || 0);
  return <span>{display % 1 === 0 ? display : display.toFixed(3)} MT</span>;
}

function ViewOrderModal({ order, onClose, onBack }) {
  if (!order) return null;
  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">
          <div className="modal-header bg-info text-white d-flex align-items-center justify-content-between">
            <div className="d-flex align-items-center gap-2">
              {onBack && (
                <button type="button" className="btn btn-sm btn-light" onClick={onBack} title="Go back">
                  ← Back
                </button>
              )}
              <h5 className="modal-title mb-0">📋 Order #{order.order_id} — Details</h5>
            </div>
            <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
          </div>
          <div className="modal-body" style={{ maxHeight: '70vh', overflowY: 'auto' }}>
            {/* Order Info */}
            <h6 className="fw-bold text-muted mb-3 text-uppercase small">Order Information</h6>
            <div className="row g-3 mb-4">
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Dealer</div>
                  <div className="fw-semibold">{order.dealer_name || '—'}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Order Date</div>
                  <div className="fw-semibold">{fmt(order.order_date)}</div>
                </div>
              </div>
              <div className="col-md-4">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Status</div>
                  <div><StatusBadge status={order.order_status} /></div>
                </div>
              </div>
              <div className="col-12">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small mb-2 fw-semibold">📋 Dealer Orders</div>
                  <table className="table table-sm table-bordered mb-0" style={{ fontSize: '.88rem' }}>
                    <thead className="table-light">
                      <tr>
                        <th>Product</th>
                        <th style={{ width: 90 }}>Bags</th>
                        <th style={{ width: 110 }}>Qty (MT)</th>
                      </tr>
                    </thead>
                    <tbody>
                      {order.items && order.items.length > 0 ? (
                        order.items.map((item, idx) => (
                          <tr key={idx}>
                            <td>{item.product_name || `#${item.product_id}`}</td>
                            <td>{item.order_bags || '—'}</td>
                            <td>{parseFloat(item.order_quantity).toFixed(3)}</td>
                          </tr>
                        ))
                      ) : (
                        <tr><td colSpan={3} className="text-muted text-center py-2">No items</td></tr>
                      )}
                    </tbody>
                  </table>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Party</div>
                  <div className="fw-semibold">{order.party_company_name || order.party_name_col || '—'}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Party Phone</div>
                  <div className="fw-semibold">
                    {order.party_phone
                      ? <a href={`tel:${order.party_phone}`}>{order.party_phone}</a>
                      : '—'}
                  </div>
                </div>
              </div>
              <div className="col-12">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Delivery Address</div>
                  <div className="fw-semibold">{order.party_address || '—'}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Load Type</div>
                  <div className="fw-semibold">{order.load_type_desc || order.load_type_code || '—'}</div>
                </div>
              </div>
              <div className="col-md-6">
                <div className="p-3 bg-light rounded">
                  <div className="text-muted small">Preferred Loading Location</div>
                  <div className="fw-semibold">{order.preferred_location_desc || order.preferred_location_code || '—'}</div>
                </div>
              </div>

              {/* Self DOT Driver Details (if applicable) */}
              {order.load_type_code === 'SLF_DOT' && (order.driver_name_on_order || order.driver_phone_on_order || order.vehicle_number_on_order) && (
                <div className="col-12">
                  <div className="p-3 border rounded" style={{ background: '#f0f8ff', borderColor: '#b0d4f1' }}>
                    <div className="fw-semibold small text-primary mb-3">🚛 Self DOT — Driver Details</div>
                    <div className="row g-3">
                      <div className="col-md-4">
                        <div className="text-muted small">Driver Name</div>
                        <div className="fw-semibold">{order.driver_name_on_order || '—'}</div>
                      </div>
                      <div className="col-md-4">
                        <div className="text-muted small">Driver Phone</div>
                        <div className="fw-semibold">{order.driver_phone_on_order || '—'}</div>
                      </div>
                      <div className="col-md-4">
                        <div className="text-muted small">Vehicle Number</div>
                        <div className="fw-semibold">{order.vehicle_number_on_order || '—'}</div>
                      </div>
                    </div>
                  </div>
                </div>
              )}
            </div>

            {/* Dispatch Info */}
