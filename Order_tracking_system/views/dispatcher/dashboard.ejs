function PendingDealersModal({ orders, onSelectDealer, onClose }) {
  const pendingOrders = orders.filter(o => o.order_status === 'ORDER_PLACED' || o.order_status === 'ACCEPTED');
  const dealerMap = {};

  pendingOrders.forEach(o => {
    if (!dealerMap[o.dealer_id]) {
      dealerMap[o.dealer_id] = {
        dealer_id: o.dealer_id,
        dealer_name: o.dealer_name,
        dealer_login_name: o.dealer_login_name,
        dealer_company_name: o.dealer_company_name,
        count: 0,
      };
    }
    dealerMap[o.dealer_id].count++;
  });

  const dealers = Object.values(dealerMap).sort((a, b) => b.count - a.count);

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.55)' }}>
      <div className="modal-dialog modal-dialog-centered">
        <div className="modal-content">
