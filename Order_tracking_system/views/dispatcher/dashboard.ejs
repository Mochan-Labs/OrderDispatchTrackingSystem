                </button>
              )}
              <h5 className="modal-title mb-0">⏳ Pending Orders — {dealerName}</h5>
            </div>
            <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
          </div>
          <div className="modal-body" style={{ maxHeight: '70vh', overflowY: 'auto' }}>
            {dealerOrders.length === 0 ? (
              <p className="text-muted text-center py-3">No pending orders</p>
            ) : (
              <div className="list-group">
                {dealerOrders.map(order => (
                  <div key={order.order_id} className="list-group-item" style={{ padding: '1rem' }}>
                    <div className="d-flex justify-content-between align-items-start mb-2">
                      <div>
                        <div className="fw-semibold">Order #{order.order_id}</div>
                        <small className="text-muted">{fmt(order.order_date)}</small>
                      </div>
                      <StatusBadge status={order.order_status} dispatchStatus={order.dispatch_status} />
                    </div>
                    <div className="row g-2 small mb-3">
                      <div className="col-6 col-sm-3">
                        <div className="text-muted">Product</div>
                        <div className="fw-semibold">{parseItems(order)[0]?.product_name || '—'}</div>
                      </div>
                      <div className="col-6 col-sm-3">
                        <div className="text-muted">Qty (MT)</div>
                        <div className="fw-semibold">{(() => {
                          const items = parseItems(order);
                          const total = items.reduce((s, i) => s + parseFloat(i.order_quantity || 0), 0);
                          return total > 0 ? total.toFixed(3) : order.order_quantity || '—';
                        })()}</div>
                      </div>
                      <div className="col-6 col-sm-3">
                        <div className="text-muted">Party</div>
                        <div className="fw-semibold">{order.party_company_name || order.party_name_col || '—'}</div>
                      </div>
                      <div className="col-6 col-sm-3">
