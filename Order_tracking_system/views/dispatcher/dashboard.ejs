                {/* Receipt display section for edit mode */}
                <div className="mb-4 p-3 border rounded" style={{ background: '#f9f9f9', borderColor: '#ddd' }}>
                <h6 className="fw-bold text-muted text-uppercase small mb-3">📸 Receipt Photo</h6>
                {currentReceiptUrl && !uploadedImageUrl ? (
                  <>
                    <img
                      src={currentReceiptUrl}
                      alt="Current dispatch receipt"
                      style={{
                        maxWidth: '100%',
                        maxHeight: '250px',
                        borderRadius: '8px',
                        border: '1px solid #dee2e6',
                        marginBottom: '12px',
                        cursor: 'pointer'
                      }}
                      onClick={() => window.open(currentReceiptUrl, '_blank')}
