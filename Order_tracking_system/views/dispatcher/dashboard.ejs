                        <button className="btn btn-sm btn-success" onClick={() => onDispatch(o)}>🚛 Dispatch</button>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}

