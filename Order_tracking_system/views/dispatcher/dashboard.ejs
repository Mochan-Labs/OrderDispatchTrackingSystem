function DealerGroup({ orders, onAccept, onDispatch, onView, isOrderOverdue }) {
  const [expanded, setExpanded] = useState(true);

  const placedCount    = orders.filter(o => o.order_status === 'ORDER_PLACED').length;
  const acceptedCount  = orders.filter(o => o.order_status === 'ACCEPTED').length;
  const onHoldCount    = orders.filter(o => o.order_status === 'ON_HOLD').length;
  const dispatchedCount = orders.filter(o => ['PARTIALLY_DISPATCHED', 'DISPATCH_ON_HOLD', 'FULLY_DISPATCHED'].includes(o.order_status)).length;

  const first       = orders[0];
  const displayName = first.dealer_login_name || first.dealer_company_name || first.dealer_name || `Dealer #${first.dealer_id}`;
  const subName     = (first.dealer_company_name && first.dealer_login_name && first.dealer_company_name !== first.dealer_login_name)
    ? first.dealer_company_name
    : null;

  return (
    <div className="card mb-3 shadow-sm">
      <div
        className="card-header d-flex align-items-center justify-content-between"
