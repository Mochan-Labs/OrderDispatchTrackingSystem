        <div className="d-flex align-items-center gap-2 flex-wrap">
          {placedCount    > 0 && <span className="badge" style={{ background: '#fd7e14', color: '#fff' }}>🕐 {placedCount} Placed</span>}
          {acceptedCount  > 0 && <span className="badge" style={{ background: '#0dcaf0', color: '#000' }}>✅ {acceptedCount} Accepted</span>}
          {onHoldCount    > 0 && <span className="badge" style={{ background: '#e57373', color: '#fff' }}>⏸️ {onHoldCount} On Hold</span>}
          {dispatchedCount > 0 && <span className="badge" style={{ background: '#198754', color: '#fff' }}>🚛 {dispatchedCount} Dispatched</span>}
          <span className="text-muted ms-1">{expanded ? '▲' : '▼'}</span>
        </div>
      </div>

      {expanded && (
        <div className="card-body p-0">
          <div className="table-responsive">
            <table className="table table-hover table-sm mb-0" style={{ fontSize: '.87rem' }}>
              <thead className="table-light">
                <tr>
                  <th>Order#</th>
                  <th>Time</th>
                  <th>Product</th>
                  <th>Qty</th>
                  <th>Party</th>
                  <th className="d-none d-lg-table-cell">Address</th>
                  <th className="d-none d-md-table-cell">Contact</th>
                  <th className="d-none d-xl-table-cell">Load Type</th>
                  <th className="d-none d-xl-table-cell">Pref. Location</th>
                  <th className="d-none d-lg-table-cell">Actual Location</th>
                  <th>Status</th>
                  <th>Action</th>
                </tr>
              </thead>
              <tbody>
                {orders.map(o => (
                  <OrderRow
                    key={o.order_id}
                    order={o}
                    onAccept={onAccept}
                    onDispatch={onDispatch}
                    onView={onView}
                    
                    isOrderOverdue={isOrderOverdue}
                  />
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
    </div>
  );
}

function App() {
  const getDefaultDates = () => {
    const end = new Date();
    const start = new Date();
    start.setDate(start.getDate() - 3); // Last 3 days
    return {
      start: start.toISOString().slice(0, 10),
      end: end.toISOString().slice(0, 10),
    };
  };
  const defaults = getDefaultDates();

  const [orders,          setOrders]          = useState([]);
  const [loading,         setLoading]         = useState(true);
  const [search,          setSearch]          = useState('');
  const [showOnHold,      setShowOnHold]      = useState(true);
  const [showDispatched,  setShowDispatched]  = useState(true);
  const [dispatchModal,   setDispatchModal]   = useState(null);
  const [viewOrder,       setViewOrder]       = useState(null);
  const [loadingLocs,     setLoadingLocs]     = useState([]);
  const [toast,           setToast]           = useState(null);
  const [refreshing,      setRefreshing]      = useState(false);
  const [showPendingDealers, setShowPendingDealers] = useState(false);
  const [selectedDealerId, setSelectedDealerId] = useState(null);
  const [showDispatchedDealers, setShowDispatchedDealers] = useState(false);
  const [selectedDispatchedDealerId, setSelectedDispatchedDealerId] = useState(null);
  const [startDate,       setStartDate]       = useState(defaults.start);
  const [endDate,         setEndDate]         = useState(defaults.end);
  const [showOverdueDealers, setShowOverdueDealers] = useState(false);
  const [selectedOverdueDealerId, setSelectedOverdueDealerId] = useState(null);
  const [showTotalDealers, setShowTotalDealers] = useState(false);
  const [selectedTotalDealerId, setSelectedTotalDealerId] = useState(null);
  const [showTotalOrdersList, setShowTotalOrdersList] = useState(false);
  const [allOverdueOrders, setAllOverdueOrders] = useState([]);
  const esRef = useRef(null);
  const retryRef = useRef(null);

  const notify = (msg, type = 'success') => setToast({ msg, type });

  const isOrderOverdue = (order) => {
    if (['PARTIALLY_DISPATCHED', 'DISPATCH_ON_HOLD', 'FULLY_DISPATCHED'].includes(order.order_status)) return false; // Not overdue if in dispatch state
    const orderDate = new Date(order.order_date);
    const now = new Date();
    const daysDiff = Math.floor((now - orderDate) / (1000 * 60 * 60 * 24));
    return daysDiff > 3; // Overdue if older than 3 days
  };

  const overdueCounts = {
    total: allOverdueOrders.length,
    byDealer: {}
  };
  allOverdueOrders.forEach(o => {
    if (!overdueCounts.byDealer[o.dealer_id]) {
      overdueCounts.byDealer[o.dealer_id] = { dealer_id: o.dealer_id, dealer_name: o.dealer_name, count: 0 };
    }
    overdueCounts.byDealer[o.dealer_id].count++;
  });

  const totalDealerCounts = {
    total: new Set(orders.map(o => o.dealer_id)).size,
    byStatus: {}
  };
  const dealerMap = {};
  orders.forEach(o => {
    if (!dealerMap[o.dealer_id]) {
      dealerMap[o.dealer_id] = {
        dealer_id: o.dealer_id,
        dealer_name: o.dealer_name,
        dealer_login_name: o.dealer_login_name,
        dealer_company_name: o.dealer_company_name,
        total: 0,
        byStatus: { ORDER_PLACED: 0, ACCEPTED: 0, ON_HOLD: 0 }
      };
    }
    dealerMap[o.dealer_id].byStatus[o.order_status] = (dealerMap[o.dealer_id].byStatus[o.order_status] || 0) + 1;
    dealerMap[o.dealer_id].total++;
  });

  const fetchOrders = useCallback(async () => {
    setLoading(true);
    // Build status filter based on toggles
    const statuses = ['ORDER_PLACED', 'ACCEPTED'];
    if (showDispatched) {
      // When toggle ON, include all dispatch-related statuses
      statuses.push('PARTIALLY_DISPATCHED', 'DISPATCH_ON_HOLD', 'FULLY_DISPATCHED');
    }
    if (showOnHold)     statuses.push('ON_HOLD');
    try {
      const params = new URLSearchParams();
      params.set('statuses', statuses.join(','));
      if (startDate) params.set('startDate', startDate);
      if (endDate) params.set('endDate', endDate);
      const r    = await fetch(`/api/dispatcher/orders?${params.toString()}`);
      const data = await r.json();
      setOrders(Array.isArray(data) ? data : []);
    } catch {
      notify('Failed to load orders', 'error');
    }
    setLoading(false);
  }, [showOnHold, showDispatched, startDate, endDate]);

  useEffect(() => { fetchOrders(); }, [fetchOrders]);

  // Fetch ALL overdue orders (ignoring date filter)
  useEffect(() => {
    const fetchAllOverdue = async () => {
      try {
        const statuses = ['ORDER_PLACED', 'ACCEPTED', 'ON_HOLD'];
        const params = new URLSearchParams();
        params.set('statuses', statuses.join(','));
        // No startDate/endDate params - fetch all
        const r = await fetch(`/api/dispatcher/orders?${params.toString()}`);
        const data = await r.json();
        if (Array.isArray(data)) {
          setAllOverdueOrders(data.filter(isOrderOverdue));
        }
      } catch (e) {
        console.error('Failed to fetch overdue orders:', e);
      }
    };
    fetchAllOverdue();
  }, []);

  useEffect(() => {
    // Fetch warehouses from warehouse_master to join with warehouse_inventory
    fetch('/api/warehouses-dropdown')
      .then(r => r.json())
      .then(d => setLoadingLocs(Array.isArray(d) ? d : []))
      .catch(() => {});
  }, []);

  // SSE listener for real-time order status updates
  useEffect(() => {
    function connect() {
      const es = new EventSource('/api/orders/events', { withCredentials: true });
      esRef.current = es;
      es.addEventListener('order-status-changed', () => {
        setRefreshing(true);
        fetchOrders().finally(() => setRefreshing(false));
      });
      es.onerror = () => {
        es.close();
        esRef.current = null;
        retryRef.current = setTimeout(connect, 3000);
      };
    }
    connect();
    return () => { esRef.current?.close(); clearTimeout(retryRef.current); };
  }, [fetchOrders]);

  const handleAccept = async (orderId) => {
    const r = await fetch(`/api/dispatcher/orders/${orderId}/accept`, { method: 'POST' });
    if (r.ok) {
      notify(`Order #${orderId} accepted`);
      fetchOrders();
    } else {
      const d = await r.json().catch(() => ({}));
      notify(d.error || 'Failed to accept order', 'error');
    }
  };

  const handleDispatch = async (orderId, form) => {
    const r = await fetch(`/api/dispatcher/orders/${orderId}/dispatch`, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json' },
      body:    JSON.stringify(form),
    });
    if (r.ok) {
      notify(`Order #${orderId} dispatched successfully`);
      setDispatchModal(null);
      fetchOrders();
    } else {
      const d = await r.json().catch(() => ({}));
      notify(d.error || 'Failed to dispatch', 'error');
    }
  };

  const exportDispatcherExcel = () => {
    const data = [];
    orders.forEach(o => {
      // Use order_status directly (now contains dispatch status too)
      const realStatus = o.order_status.toLowerCase();
      const deliveryLocation = o.preferred_location_desc || o.preferred_location_code || '';
      const items = o.items && Array.isArray(o.items) ? o.items : [];

      if (items.length > 0) {
        items.forEach(item => {
          data.push({
            'Order Id': o.order_id,
            'Dealer Name': o.dealer_name || o.dealer_login_name || '',
            'Dealer Company Name': o.dealer_company_name || '',
            'Product': item.product_name || '',
            'Status': realStatus,
            'Order Date': fmt(o.order_date),
            'Order Bags': item.order_bags || '',
            'Order Qty': item.order_quantity || '',
            'Dispatch Date': o.dispatch_created_at ? fmt(o.dispatch_created_at) : '',
            'Delivery Location': deliveryLocation,
            'Vehicle No': o.dispatch_vehicle_number || o.vehicle_number_on_order || '',
            'Driver Name': o.dispatch_driver_name || o.driver_name_on_order || '',
            'Driver Phone': o.dispatch_driver_phone || o.driver_phone_on_order || '',
            'Bilty No': o.bilty_number || '',
            'Remarks': o.remarks || '',
            'Party': o.party_name || o.party_company_name || o.party_name_col || '',
            'Address': o.party_address || '',
            'Load Type': o.load_type_desc || o.load_type_code || '',
            'Preferred Location': o.preferred_location_desc || o.preferred_location_code || '',
            'Actual Location': o.actual_location_desc || o.actual_loading_location_code || '',
          });
        });
      } else {
        data.push({
          'Order Id': o.order_id,
          'Dealer Name': o.dealer_name || o.dealer_login_name || '',
          'Dealer Company Name': o.dealer_company_name || '',
          'Product': o.product_name || '',
          'Status': realStatus,
          'Order Date': fmt(o.order_date),
          'Order Bags': o.order_bags || '',
          'Order Qty': o.order_quantity || '',
          'Dispatch Date': o.dispatch_created_at ? fmt(o.dispatch_created_at) : '',
          'Delivery Location': deliveryLocation,
          'Vehicle No': o.dispatch_vehicle_number || o.vehicle_number_on_order || '',
          'Driver Name': o.dispatch_driver_name || o.driver_name_on_order || '',
          'Driver Phone': o.dispatch_driver_phone || o.driver_phone_on_order || '',
          'Bilty No': o.bilty_number || '',
          'Remarks': o.remarks || '',
          'Party': o.party_name || o.party_company_name || o.party_name_col || '',
          'Address': o.party_address || '',
          'Load Type': o.load_type_desc || o.load_type_code || '',
          'Preferred Location': o.preferred_location_desc || o.preferred_location_code || '',
          'Actual Location': o.actual_location_desc || o.actual_loading_location_code || '',
        });
      }
    });
    const ws = XLSX.utils.json_to_sheet(data);
    const wb = XLSX.utils.book_new();
    XLSX.utils.book_append_sheet(wb, ws, 'Dispatcher Orders');
    XLSX.writeFile(wb, 'Dispatcher_Orders.xlsx');
  };

  // Filter by search term
  const filtered = orders.filter(o => {
    if (!search) return true;
    const searchLower = search.toLowerCase();
    return (
      (o.product_name && o.product_name.toLowerCase().includes(searchLower)) ||
      (o.party_name_col && o.party_name_col.toLowerCase().includes(searchLower)) ||
      (o.order_id && o.order_id.toString().includes(searchLower)) ||
      (o.dealer_name && o.dealer_name.toLowerCase().includes(searchLower)) ||
      (o.party_address && o.party_address.toLowerCase().includes(searchLower))
    );
  });

  // Group by dealer_id, preserve insertion order (already sorted by dealer_id, order_date ASC from API)
  const dealerGroups = {};
  filtered.forEach(o => {
    if (!dealerGroups[o.dealer_id]) dealerGroups[o.dealer_id] = [];
    dealerGroups[o.dealer_id].push(o);
  });

  const totalPending   = orders.filter(o => o.order_status === 'ORDER_PLACED' || o.order_status === 'ACCEPTED').length;
  const totalDispatched = orders.filter(o => ['PARTIALLY_DISPATCHED', 'DISPATCH_ON_HOLD', 'FULLY_DISPATCHED'].includes(o.order_status)).length;
  const totalDealers   = Object.keys(dealerGroups).length;

  return (
    <div>
      {refreshing && (
        <div style={{
          position: 'fixed', top: 0, left: 0, right: 0, zIndex: 9999,
          backgroundColor: '#0d6efd', color: '#fff',
          textAlign: 'center', padding: '4px 0',
          fontSize: '0.85rem', fontWeight: 500
        }}>
          Refreshing orders...
        </div>
      )}
      {toast && <Toast msg={toast.msg} type={toast.type} onClose={() => setToast(null)} />}

      {dispatchModal && (
        <DispatchModal
          order={dispatchModal}
          loadingLocations={loadingLocs}
          onSubmit={handleDispatch}
          onClose={() => setDispatchModal(null)}
          notify={notify}
          onRefresh={fetchOrders}
        />
      )}

      {viewOrder && (
        <ViewOrderModal
          order={viewOrder}
          onClose={() => setViewOrder(null)}
          onBack={(selectedDealerId || selectedDispatchedDealerId) ? () => setViewOrder(null) : undefined}
        />
      )}

      {showPendingDealers && (
        <PendingDealersModal
          orders={orders}
          onSelectDealer={dealerId => {
            setSelectedDealerId(dealerId);
            setShowPendingDealers(false);
          }}
          onClose={() => setShowPendingDealers(false)}
        />
      )}

      {selectedDealerId && !viewOrder && (
        <DealerOrdersModal
          orders={orders}
          dealerId={selectedDealerId}
          onClose={() => setSelectedDealerId(null)}
          onBack={() => {
            setSelectedDealerId(null);
            setShowPendingDealers(true);
          }}
          onAccept={handleAccept}
          onDispatch={order => {
            setDispatchModal(order);
            setSelectedDealerId(null);
          }}
          onView={order => {
            setViewOrder(order);
          }}
          
        />
      )}

      {showDispatchedDealers && (
        <DispatchedDealersModal
          orders={orders}
          onSelectDealer={dealerId => {
            setSelectedDispatchedDealerId(dealerId);
            setShowDispatchedDealers(false);
          }}
          onClose={() => setShowDispatchedDealers(false)}
        />
      )}

      {selectedDispatchedDealerId && !viewOrder && (
        <DealerDispatchedOrdersModal
          orders={orders}
          dealerId={selectedDispatchedDealerId}
          onClose={() => setSelectedDispatchedDealerId(null)}
          onBack={() => {
            setSelectedDispatchedDealerId(null);
            setShowDispatchedDealers(true);
          }}
          onView={order => {
            setViewOrder(order);
          }}
          onDispatch={order => {
            setDispatchModal(order);
            setSelectedDispatchedDealerId(null);
          }}
        />
      )}

      {/* Modal for Total Orders List */}
      {showTotalOrdersList && (
        <TotalOrdersListModal
          orders={orders}
          onClose={() => setShowTotalOrdersList(false)}
          onView={order => {
            setViewOrder(order);
            setShowTotalOrdersList(false);
          }}
          onAccept={handleAccept}
          onDispatch={order => {
            setDispatchModal(order);
            setShowTotalOrdersList(false);
          }}
        />
      )}

      {/* Modals for new cards */}
      {showOverdueDealers && (
        <OverdueDealersModal
          orders={allOverdueOrders}
          isOrderOverdue={isOrderOverdue}
          onSelectDealer={dealerId => {
            setSelectedOverdueDealerId(dealerId);
            setShowOverdueDealers(false);
          }}
          onClose={() => setShowOverdueDealers(false)}
        />
      )}
      {selectedOverdueDealerId && (
        <OverdueOrdersModal
          orders={allOverdueOrders}
          dealerId={selectedOverdueDealerId}
          isOrderOverdue={isOrderOverdue}
          onClose={() => setSelectedOverdueDealerId(null)}
          onBack={() => {
            setSelectedOverdueDealerId(null);
            setShowOverdueDealers(true);
          }}
          onView={order => {
            setViewOrder(order);
            setSelectedOverdueDealerId(null);
          }}
          onAccept={handleAccept}
          onDispatch={order => {
            setDispatchModal(order);
            setSelectedOverdueDealerId(null);
          }}
        />
      )}
      {showTotalDealers && (
        <TotalDealersModal
          dealerMap={dealerMap}
          onSelectDealer={dealerId => {
            setSelectedTotalDealerId(dealerId);
            setShowTotalDealers(false);
          }}
          onClose={() => setShowTotalDealers(false)}
        />
      )}
      {selectedTotalDealerId && (
        <TotalDealerOrdersModal
          orders={orders}
          dealerId={selectedTotalDealerId}
          onClose={() => setSelectedTotalDealerId(null)}
          onBack={() => {
            setSelectedTotalDealerId(null);
            setShowTotalDealers(true);
          }}
          onView={order => {
            setViewOrder(order);
            setSelectedTotalDealerId(null);
          }}
          onAccept={handleAccept}
          onDispatch={order => {
            setDispatchModal(order);
            setSelectedTotalDealerId(null);
          }}
          
        />
      )}

      {/* Stats */}
      <div className="row g-3 mb-4">
        <div className="col-6 col-md-3 col-lg-2">
          <div
            className={`card border-0 shadow-sm count-card ${orders.length === 0 ? 'disabled' : ''}`}
            style={{ borderLeft: '4px solid #0d6efd' }}
            title="Last 3 days Orders"
            onClick={() => orders.length > 0 && setShowTotalDealers(true)}
          >
            <div className="card-body d-flex align-items-center gap-3 py-3">
              <span style={{ fontSize: '1.8rem' }}>📋</span>
              <div>
                <div className="fs-4 fw-bold">{orders.length}</div>
                <div className="text-muted small">Total Orders</div>
              </div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-3 col-lg-2">
          <div
            className={`card border-0 shadow-sm count-card ${overdueCounts.total === 0 ? 'disabled' : ''}`}
            style={{ borderLeft: '4px solid #dc3545' }}
            title="All Overdue orders from history"
            onClick={() => overdueCounts.total > 0 && setShowOverdueDealers(true)}
          >
            <div className="card-body d-flex align-items-center gap-3 py-3">
              <span style={{ fontSize: '1.8rem' }}>⚠️</span>
              <div>
                <div className="fs-4 fw-bold">{overdueCounts.total}</div>
                <div className="text-muted small">Overdue</div>
              </div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-3 col-lg-2">
          <div
            className={`card border-0 shadow-sm count-card ${totalPending === 0 ? 'disabled' : ''}`}
            style={{ borderLeft: '4px solid #fd7e14' }}
            title="Last 3 days Pending Orders"
            onClick={() => totalPending > 0 && setShowPendingDealers(true)}
          >
            <div className="card-body d-flex align-items-center gap-3 py-3">
              <span style={{ fontSize: '1.8rem' }}>⏳</span>
              <div>
                <div className="fs-4 fw-bold">{totalPending}</div>
                <div className="text-muted small">Pending</div>
              </div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-3 col-lg-2">
          <div
            className={`card border-0 shadow-sm count-card ${totalDispatched === 0 ? 'disabled' : ''}`}
            style={{ borderLeft: '4px solid #198754' }}
            title="Last 3 days dispatched orders"
            onClick={() => totalDispatched > 0 && setShowDispatchedDealers(true)}
          >
            <div className="card-body d-flex align-items-center gap-3 py-3">
              <span style={{ fontSize: '1.8rem' }}>🚛</span>
              <div>
                <div className="fs-4 fw-bold">{totalDispatched}</div>
                <div className="text-muted small">Dispatched</div>
              </div>
            </div>
          </div>
        </div>
        <div className="col-6 col-md-3 col-lg-2">
          <div className="card border-0 shadow-sm" style={{ borderLeft: '4px solid #6f42c1' }} title="Last 3 days active dealers">
            <div className="card-body d-flex align-items-center gap-3 py-3">
              <span style={{ fontSize: '1.8rem' }}>🏬</span>
              <div>
                <div className="fs-4 fw-bold">{totalDealers}</div>
                <div className="text-muted small">Active Dealers</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      {/* Filters */}
      <div className="d-flex align-items-center gap-3 mb-4 flex-wrap p-3 bg-white rounded shadow-sm">
        <span className="fw-bold text-muted small text-uppercase">Filters:</span>
        <div className="d-flex gap-2 align-items-center">
          <label className="small text-muted mb-0">From:</label>
          <input type="date" className="form-control form-control-sm" style={{width: '120px'}}
            value={startDate} onChange={e => setStartDate(e.target.value)} />
          <label className="small text-muted mb-0">To:</label>
          <input type="date" className="form-control form-control-sm" style={{width: '120px'}}
            value={endDate} onChange={e => setEndDate(e.target.value)} />
        </div>
        <div className="form-check form-switch mb-0">
          <input className="form-check-input" type="checkbox" id="toggleOnHold"
            checked={showOnHold} onChange={e => setShowOnHold(e.target.checked)} />
          <label className="form-check-label" htmlFor="toggleOnHold">⏸️ Show On Hold</label>
        </div>
        <div className="form-check form-switch mb-0">
          <input className="form-check-input" type="checkbox" id="toggleDispatched"
            checked={showDispatched} onChange={e => setShowDispatched(e.target.checked)} />
          <label className="form-check-label" htmlFor="toggleDispatched">🚛 Show Dispatched</label>
        </div>
        <div className="ms-auto d-flex gap-2">
          <button className="btn btn-sm btn-outline-success" onClick={exportDispatcherExcel} disabled={orders.length === 0}>
            ⬇️ Download
          </button>
          <button className="btn btn-sm btn-outline-secondary" onClick={fetchOrders} disabled={loading}>
            {loading
              ? <span className="spinner-border spinner-border-sm"></span>
              : '🔄'} Refresh
          </button>
        </div>
      </div>

      {/* Search */}
      <div className="mb-3">
        <input className="form-control form-control-sm" placeholder="Search by product, party, dealer, address, order ID…"
          value={search} onChange={e => setSearch(e.target.value)} />
      </div>

      {/* Content */}
      {loading ? (
        <div className="text-center py-5 text-muted">
          <div className="spinner-border mb-3" role="status"></div>
          <div>Loading orders…</div>
        </div>
      ) : Object.keys(dealerGroups).length === 0 ? (
        <div className="text-center py-5">
          <div style={{ fontSize: '3rem' }}>📭</div>
          <h5 className="text-muted mt-3">No active orders</h5>
          <p className="text-muted small">All orders are dispatched or there are no pending orders.</p>
        </div>
      ) : (
        Object.entries(dealerGroups).map(([dealerId, dealerOrders]) => (
          <DealerGroup
            key={dealerId}
            orders={dealerOrders}
            onAccept={handleAccept}
            onDispatch={order => setDispatchModal(order)}
            onView={order => setViewOrder(order)}
            
            isOrderOverdue={isOrderOverdue}
          />
        ))
      )}

    </div>
  );
}

ReactDOM.createRoot(document.getElementById('app-root')).render(<App />);
</script>

<%- include('../partials/footer') %>
