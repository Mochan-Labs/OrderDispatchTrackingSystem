                  <div className="col-md-6">
                    <label className="form-label fw-semibold">Bilty Number</label>
                    <input
                      type="text"
                      className="form-control"
                      value={form.bilty_number || order.bilty_number || ''}
                      onChange={(e) => setForm(f => ({ ...f, bilty_number: e.target.value }))}
                    />
                  </div>
