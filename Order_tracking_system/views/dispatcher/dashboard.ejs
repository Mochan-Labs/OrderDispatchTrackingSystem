                      </div>
                    </div>
                    {/* Action buttons */}
                    <div className="d-flex gap-2 flex-wrap" style={{ marginTop: '0.75rem' }}>
                      <button className="btn btn-sm btn-outline-primary" onClick={() => onView(order)}>
