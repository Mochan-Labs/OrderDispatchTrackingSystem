                      <div className="mb-3">
                        <img
                          src={uploadedImageUrl}
                          alt="Receipt preview"
                          style={{
                            maxWidth: '100%',
                            maxHeight: '300px',
                            borderRadius: '8px',
                            border: '1px solid #dee2e6',
                            cursor: 'pointer'
