                        📥 Download
                      </button>
                      <button
                        type="button"
                        className="btn btn-sm btn-outline-secondary flex-grow-1"
                        onClick={() => galleryInputRef.current?.click()}
                        disabled={uploading}
                      >
                        🔄 Replace Receipt
                      </button>
                      <button
                        type="button"
                        className="btn btn-sm btn-outline-danger flex-grow-1"
                        onClick={handleDeleteCurrentReceipt}
                      >
                        🗑️ Delete Receipt
                      </button>
                    </div>
                  </>
                ) : !uploadedImageUrl ? (
                  <>
                    <div className="text-muted mb-3">No receipt uploaded for this dispatch</div>
                    <div className="d-flex gap-2 flex-column flex-sm-row">
                      <button
                        type="button"
                        className="btn btn-sm btn-outline-secondary flex-grow-1"
                        onClick={() => galleryInputRef.current?.click()}
                        disabled={uploading}
                      >
                        📁 Choose from Gallery
                      </button>
                      <button
                        type="button"
                        className="btn btn-sm btn-outline-secondary flex-grow-1"
                        onClick={() => cameraInputRef.current?.click()}
                        disabled={uploading}
                      >
                        📷 Take a Photo
                      </button>
                    </div>
                  </>
                ) : null}
                <input
                  ref={galleryInputRef}
                  type="file"
                  accept="image/*"
                  onChange={handleFileSelect}
                  style={{ display: 'none' }}
                  disabled={uploading}
                />
                <input
                  ref={cameraInputRef}
                  type="file"
                  accept="image/*"
                  capture="environment"
                  onChange={handleFileSelect}
                  style={{ display: 'none' }}
                  disabled={uploading}
                />
                {selectedFile && !uploadedImageUrl && (
                  <div className="mt-3">
                    <div className="text-muted small mb-2">Selected: {selectedFile.name}</div>
                    <button
                      type="button"
                      className="btn btn-sm btn-primary"
                      onClick={uploadReceipt}
                      disabled={uploading}
                    >
                      {uploading ? `Uploading ${uploadProgress}%...` : 'Upload Selected Receipt'}
                    </button>
                    <button
                      type="button"
                      className="btn btn-sm btn-outline-secondary ms-2"
                      onClick={() => {
                        setSelectedFile(null);
                        setImagePreview(null);
                        setErr('');
                      }}
                      disabled={uploading}
                    >
                      Cancel
                    </button>
                  </div>
                )}
                {uploadedImageUrl && (
                  <div className="mt-3">
                    <div className="alert alert-success py-2 mb-3">
                      ✅ New receipt selected
                    </div>
                    <img
                      src={uploadedImageUrl}
                      alt="New receipt preview"
                      style={{
                        maxWidth: '100%',
                        maxHeight: '200px',
                        borderRadius: '8px',
                        border: '1px solid #dee2e6',
                        cursor: 'pointer'
                      }}
                      onClick={() => window.open(uploadedImageUrl, '_blank')}
                    />
                    <div className="d-flex gap-2 mt-3 flex-column flex-sm-row">
                      <button
                        type="button"
                        className="btn btn-sm btn-outline-primary flex-grow-1"
                        onClick={() => handleDownloadReceipt(uploadedImageUrl, order.order_id)}
                      >
                        📥 Download
                      </button>
                      <button
                        type="button"
                        className="btn btn-sm btn-outline-secondary flex-grow-1"
                        onClick={() => galleryInputRef.current?.click()}
                      >
                        🔄 Replace Receipt
                      </button>
                      <button
                        type="button"
                        className="btn btn-sm btn-outline-danger flex-grow-1"
                        onClick={handleDeleteReceipt}
                      >
                        🗑️ Delete Receipt
                      </button>
                    </div>
                  </div>
                )}
              </div>
              </>
            )}
          </div>

          <div className="modal-footer">
            <button className="btn btn-secondary" onClick={onClose}>Cancel</button>
            <button className="btn btn-success" disabled={saving} onClick={submit}>
              {saving && <span className="spinner-border spinner-border-sm me-1"></span>}
              {isExistingDispatch ? '💾 Save Changes' : '🚛 Confirm Dispatch'}
            </button>
          </div>

        </div>
      </div>
    </div>
  );
}

function parseItems(order) {
  const raw = order.items;
  if (!raw) return [];
  const arr = typeof raw === 'string' ? JSON.parse(raw) : raw;
  return Array.isArray(arr) ? arr.filter(i => i && i.product_id) : [];
}

function ItemsCell({ order }) {
  const items = parseItems(order);
  if (items.length === 0) return <span className="text-muted">—</span>;
  if (items.length === 1) return <span>{items[0].product_name || `#${items[0].product_id}`}</span>;
  return (
    <span>
      {items[0].product_name || `#${items[0].product_id}`}
      <span className="badge bg-secondary ms-1" style={{ fontSize: '.7rem' }}>+{items.length - 1}</span>
    </span>
  );
}

function QtyCell({ order }) {
  const items = parseItems(order);
  const total = items.reduce((s, i) => s + parseFloat(i.order_quantity || 0), 0);
  const display = total > 0 ? total : parseFloat(order.order_quantity || 0);
  return <span>{display % 1 === 0 ? display : display.toFixed(3)} MT</span>;
}

function ViewOrderModal({ order, onClose, onBack }) {
  if (!order) return null;
  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.5)' }}>
