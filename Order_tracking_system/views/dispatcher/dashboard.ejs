<%- include('../partials/header') %>
<script src="https://cdn.jsdelivr.net/npm/react@18/umd/react.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/react-dom@18/umd/react-dom.development.js"></script>
<script src="https://cdn.jsdelivr.net/npm/@babel/standalone/babel.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/browser-image-compression@2.0.0/dist/browser-image-compression.js"></script>
<script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>

<nav aria-label="breadcrumb" class="mb-3">
  <ol class="breadcrumb">
    <li class="breadcrumb-item"><a href="/dashboard">Dashboard</a></li>
    <li class="breadcrumb-item active">Dispatch Dashboard</li>
  </ol>
</nav>

<div id="app-root"></div>

<style>
  .count-card {
    cursor: pointer !important;
    transition: all 0.2s ease !important;
  }
  .count-card:hover {
    transform: translateY(-4px) !important;
    box-shadow: 0 8px 16px rgba(0,0,0,0.15) !important;
  }
  .count-card.disabled {
    cursor: default !important;
  }
  .count-card.disabled:hover {
    transform: none !important;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075) !important;
  }
</style>

<script type="text/babel">
const { useState, useEffect, useCallback, useRef } = React;

const STATUS_CONFIG = {
  ORDER_PLACED:       { text: 'Order Placed',           icon: '🕐', bg: '#fd7e14', tc: '#fff' },
  ACCEPTED:           { text: 'Accepted',               icon: '✅', bg: '#0dcaf0', tc: '#000' },
  DISPATCHED:         { text: 'Dispatched',             icon: '📦', bg: '#198754', tc: '#fff' },
  ON_HOLD:            { text: 'On Hold',                icon: '⏸️', bg: '#e57373', tc: '#fff' },
  dispatch_completed: { text: 'Fully Dispatched',       icon: '✅', bg: '#198754', tc: '#fff' },
  dispatch_partial:   { text: 'Partially Dispatched',   icon: '📦', bg: '#fd7e14', tc: '#fff' },
  dispatch_onhold:    { text: 'Dispatch on Hold',       icon: '⏸️', bg: '#e57373', tc: '#fff' },
};

const validatePhone=(val)=>val.replace(/[^0-9]/g,'').slice(0,10);
const isValidPhone=(val)=>/^\d{10}$/.test(val.replace(/[^0-9]/g,''));

function fmt(value) {
  if (!value) return '—';
  const dt = new Date(value);
  if (isNaN(dt.getTime())) return value;
  return new Intl.DateTimeFormat('en-IN', {
    day: '2-digit', month: 'short', year: 'numeric',
    hour: '2-digit', minute: '2-digit', hour12: true,
  }).format(dt);
}

function StatusBadge({ status, dispatchStatus }) {
  // Use dispatch_status if available (for dispatched orders), otherwise use order_status
  const displayStatus = dispatchStatus || status;
  const cfg = STATUS_CONFIG[displayStatus] || { bg: '#6c757d', tc: '#fff', text: displayStatus, icon: '' };
  return (
    <span className="badge" style={{ background: cfg.bg, color: cfg.tc }}>
      {cfg.icon} {cfg.text}
    </span>
  );
}

function Toast({ msg, type, onClose }) {
  useEffect(() => {
    const t = setTimeout(onClose, 4000);
    return () => clearTimeout(t);
  }, []);
  return (
    <div style={{
      position: 'fixed', top: 80, right: 20, zIndex: 9999, minWidth: 280,
      background: type === 'success' ? '#198754' : '#dc3545',
      color: '#fff', padding: '12px 18px', borderRadius: 8,
      boxShadow: '0 4px 16px rgba(0,0,0,.25)'
    }}>
      {type === 'success' ? '✅' : '❌'} {msg}
    </div>
  );
}

// Global handler for downloading receipts
function handleDownloadReceipt(imageUrl, orderId) {
  try {
    fetch(imageUrl)
      .then(response => {
        if (!response.ok) throw new Error('Failed to download receipt');
        return response.blob();
      })
      .then(blob => {
        const url = window.URL.createObjectURL(blob);
        const link = document.createElement('a');
        link.href = url;

        const timestamp = new Date().toISOString().split('T')[0];
        const ext = imageUrl.includes('jpeg') || imageUrl.includes('jpg') ? 'jpg' : 'png';
        link.download = `Receipt_Order${orderId}_${timestamp}.${ext}`;

        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
        window.URL.revokeObjectURL(url);
      });
  } catch (error) {
    console.error('Download failed:', error);
    alert('Failed to download receipt');
  }
}

function DispatchModal({ order, loadingLocations, onSubmit, onClose, notify, onRefresh }) {
  // isExistingDispatch: order is already DISPATCHED (only edit quantities)
  // isInitialDispatch: order not yet dispatched (fill in all dispatch details + quantities)
  const isExistingDispatch = order.order_status === 'DISPATCHED' || !!order.dispatch_vehicle_number;
  const items = parseItems(order);
  const totalOrderBags = items.reduce((s, i) => s + (parseInt(i.order_bags || 0)), 0);
  const totalOrderQty = items.reduce((s, i) => s + parseFloat(i.order_quantity || 0), 0);

  // Initialize form with dispatch quantities for each item
  const initialForm = {
    vehicle_number: order.load_type_code === 'SLF_DOT' ? (order.vehicle_number_on_order || '') : '',
    driver_name: order.load_type_code === 'SLF_DOT' ? (order.driver_name_on_order || '') : '',
    driver_phone: order.load_type_code === 'SLF_DOT' ? (order.driver_phone_on_order || '') : '',
    bilty_number: '',
    actual_loading_location_code: '',
  };

  // Add dispatch quantities and comments for each item
  if (items && items.length > 0) {
    items.forEach((item, idx) => {
      // Use order_dispatch_bags if it exists (not null/undefined), otherwise use order_bags
      const dispatchBags = (item.order_dispatch_bags ?? item.order_bags) || 0;
      initialForm[`dispatch_bags_${idx}`] = dispatchBags;
      const qtyPerBag = parseFloat(item.order_quantity || 0) / parseInt(item.order_bags || 1);
      const dispatchQty = (item.order_dispatch_quantity ?? (dispatchBags * qtyPerBag).toFixed(3)) || 0;
      initialForm[`dispatch_quantity_${idx}`] = dispatchQty;
      initialForm[`dispatch_comments_${idx}`] = item.order_dispatch_comments || '';
    });
  } else {
    // Single item fallback
    const dispatchBags = (order.order_dispatch_bags ?? order.bags) || 0;
    initialForm['dispatch_bags'] = dispatchBags;
    const qtyPerBag = parseFloat(order.order_quantity || order.quantity || 0) / parseInt(order.bags || 1);
    initialForm['dispatch_quantity'] = (dispatchBags * qtyPerBag).toFixed(3);
    initialForm['dispatch_comments'] = order.order_dispatch_comments || '';
  }

  // Overall dispatch comments
  initialForm['dispatch_comments'] = '';

  const [form, setForm] = useState(initialForm);
  const [saving, setSaving] = useState(false);
  const [err, setErr] = useState('');

  // Receipt upload states
  const [selectedFile, setSelectedFile] = useState(null);
  const [imagePreview, setImagePreview] = useState(null);
  const [uploading, setUploading] = useState(false);
  const [uploadProgress, setUploadProgress] = useState(0);
  const [uploadedImageUrl, setUploadedImageUrl] = useState(null);
  const [imageMetadata, setImageMetadata] = useState(null);
  const [skipUploadConfirm, setSkipUploadConfirm] = useState(false);
  const [currentReceiptUrl, setCurrentReceiptUrl] = useState(order.image_url);

  const galleryInputRef = useRef(null);
  const cameraInputRef = useRef(null);

  const set = (k, v) => setForm(f => ({ ...f, [k]: v }));

  const handleFileSelect = async (e) => {
    const file = e.target.files?.[0];
    if (!file) return;

    // Validate file type
    const validTypes = ['image/jpeg', 'image/png', 'image/jpg', 'image/gif', 'image/webp'];
    if (!validTypes.includes(file.type)) {
      setErr('Please select a valid image file (JPG, PNG, GIF, WebP)');
      return;
    }

    setSelectedFile(file);
    const reader = new FileReader();
    reader.onload = (evt) => setImagePreview(evt.target.result);
    reader.readAsDataURL(file);
    setErr('');
    setSkipUploadConfirm(false);
  };

  const handleDeleteReceipt = () => {
    setUploadedImageUrl(null);
    setImageMetadata(null);
    setSelectedFile(null);
    setImagePreview(null);
    setErr('');
  };

  const handleDeleteCurrentReceipt = async () => {
    if (!confirm('Are you sure you want to delete this receipt?')) {
      return;
    }

    try {
      const res = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch/receipt`, {
        method: 'DELETE',
        headers: { 'Content-Type': 'application/json' }
      });

      if (!res.ok) {
        const err = await res.json();
        throw new Error(err.error || 'Failed to delete receipt');
      }

      // Immediately update local state to remove receipt from UI
      setCurrentReceiptUrl(null);
      console.log('Receipt deleted successfully');
    } catch (error) {
      console.error('Delete receipt error:', error);
      setErr(error.message);
    }
  };

  const uploadReceipt = async () => {
    if (!selectedFile) return;

    try {
      setUploading(true);
      setErr('');

      let fileToUpload = selectedFile;
      let compressedSize = null;

      // Compress if file > 500KB
      if (selectedFile.size > 500 * 1024 && typeof window.ImageCompression !== 'undefined') {
        setUploadProgress(10);
        try {
          const options = {
            maxSizeMB: 0.5,
            maxWidthOrHeight: 1920,
            useWebWorker: true,
          };
          fileToUpload = await window.ImageCompression.compress(selectedFile, options);
          compressedSize = fileToUpload.size;
          console.log(`Compressed image: ${selectedFile.size} → ${fileToUpload.size} bytes`);
        } catch (compressError) {
          console.warn('Image compression failed, using original:', compressError.message);
        }
      }

      setUploadProgress(20);

      // Step 1: Request presigned URL from backend
      console.log('Requesting presigned URL from backend...');
      const presignedRes = await fetch('/api/dispatcher/presigned-url', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          order_id: order.order_id,
          dealer_id: order.dealer_id,
          file_name: fileToUpload.name,
          file_type: fileToUpload.type,
        }),
      });

      if (!presignedRes.ok) {
        const errorData = await presignedRes.json().catch(() => ({}));
        throw new Error(errorData.error || `Failed to get presigned URL: ${presignedRes.status}`);
      }

      const { url: presignedUrl, s3Key, isLocal } = await presignedRes.json();
      console.log('Presigned URL received:', s3Key, 'isLocal:', isLocal);
      setUploadProgress(40);

      let s3Url;

      if (isLocal) {
        // Local upload: POST to the upload endpoint
        console.log('Uploading file to local endpoint...');

        // Convert file to base64 using FileReader
        const fileBase64 = await new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.onload = () => {
            const dataUrl = reader.result;
            const base64 = dataUrl.includes(',') ? dataUrl.split(',')[1] : dataUrl;
            resolve(base64);
          };
          reader.onerror = reject;
          reader.readAsDataURL(fileToUpload);
        });

        const localUploadRes = await fetch(presignedUrl, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            filePath: s3Key,
            fileData: fileBase64,
            order_id: order.order_id,
            dealer_id: order.dealer_id
          })
        });

        if (!localUploadRes.ok) {
          throw new Error(`Local upload failed: ${localUploadRes.status} ${localUploadRes.statusText}`);
        }

        const localResult = await localUploadRes.json();
        s3Url = localResult.image_url;
        console.log('Receipt uploaded locally:', s3Url);
      } else {
        // S3 upload: PUT file directly to presigned URL
        console.log('Uploading file directly to S3...');
        const s3UploadRes = await fetch(presignedUrl, {
          method: 'PUT',
          body: fileToUpload,
          headers: { 'Content-Type': fileToUpload.type },
        });

        if (!s3UploadRes.ok) {
          throw new Error(`S3 upload failed: ${s3UploadRes.status} ${s3UploadRes.statusText}`);
        }

        // After successful upload, get a READ presigned URL for displaying the image
        console.log('Generating read presigned URL...');
        const s3Key = presignedUrl.split('/receipts/')[1]?.split('?')[0];
        if (s3Key) {
          const readUrlRes = await fetch('/api/dispatcher/presigned-read-url', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ s3Key: `receipts/${s3Key}` })
          });

          if (readUrlRes.ok) {
            const readResult = await readUrlRes.json();
            s3Url = readResult.url;
            console.log('Read presigned URL generated successfully');
          } else {
            throw new Error('Failed to generate read presigned URL');
          }
        } else {
          throw new Error('Could not extract S3 key from upload URL');
        }
        console.log('Receipt uploaded to S3:', s3Url);
      }

      setUploadProgress(80);
      setUploadProgress(95);

      // Store metadata
      setUploadedImageUrl(s3Url);
      setImageMetadata({
        image_url: s3Url,
        image_type: fileToUpload.type,
        image_original_size: selectedFile.size,
        image_compressed_size: compressedSize,
      });

      setUploadProgress(100);
      setUploading(false);
    } catch (error) {
      console.error('Upload error:', error);
      setErr(`Upload failed: ${error.message}`);
      setUploading(false);
      setUploadProgress(0);
    }
  };

  const submit = async () => {
    console.log('[DispatchModal] Submit - isExistingDispatch:', isExistingDispatch, 'order_status:', order.order_status, 'dispatch_vehicle_number:', order.dispatch_vehicle_number);

    // Validate dispatch form fields (always required for initial dispatch)
    if (!isExistingDispatch) {
      if (!form.vehicle_number.trim())                return setErr('Vehicle number is required');
      if (!form.driver_phone.trim())                  return setErr('Driver phone is required');
      if (!/^\d{10}$/.test(form.driver_phone.trim())) return setErr('Driver phone must be exactly 10 digits');
      if (!form.bilty_number.trim())                  return setErr('Bilty number is required');
      if (!form.actual_loading_location_code)         return setErr('Actual loading location is required');

      // Check if image is selected but not uploaded
      if (selectedFile && !uploadedImageUrl && !skipUploadConfirm) {
        setSkipUploadConfirm(true);
        return;
      }
    }

    setErr('');
    setSaving(true);

    try {
      if (isExistingDispatch) {
        // Editing existing dispatch: save dispatch quantities, comments, and details
        const dispatchQuantities = items.map((item, idx) => ({
          item_id: item.item_id,
          dispatch_bags: parseInt(form[`dispatch_bags_${idx}`] !== undefined ? form[`dispatch_bags_${idx}`] : (item.order_dispatch_bags || item.order_bags || 0)),
          dispatch_quantity: parseFloat(form[`dispatch_quantity_${idx}`] !== undefined ? form[`dispatch_quantity_${idx}`] : (item.order_dispatch_quantity || item.order_quantity || 0)),
          dispatch_comments: form.dispatch_comments || item.order_dispatch_comments || ''
        }));

        console.log('[Edit Dispatch] Sending to backend:', JSON.stringify(dispatchQuantities, null, 2));

        // Update dispatch record with new details (including new receipt if uploaded)
        const updatePayload = {
          vehicle_number: form.vehicle_number || order.dispatch_vehicle_number,
          driver_name: form.driver_name || order.dispatch_driver_name,
          driver_phone: form.driver_phone || order.dispatch_driver_phone,
          bilty_number: form.bilty_number || order.bilty_number,
          actual_loading_location_code: form.actual_loading_location_code || order.actual_loading_location_code
        };

        // Include new receipt metadata if one was uploaded
        if (imageMetadata) {
          updatePayload.image_url = imageMetadata.image_url;
          updatePayload.image_type = imageMetadata.image_type;
          updatePayload.image_original_size = imageMetadata.image_original_size;
          updatePayload.image_compressed_size = imageMetadata.image_compressed_size;
        }

        const dispatchUpdateRes = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(updatePayload)
        });

        if (!dispatchUpdateRes.ok) {
          const err = await dispatchUpdateRes.json();
          throw new Error(err.error || 'Failed to update dispatch details');
        }

        // Update quantities and comments
        const res = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch-quantities`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ dispatchQuantities })
        });

        const data = await res.json();
        if (!res.ok) throw new Error(data.error || 'Failed to update dispatch quantities');

        notify(`✅ Dispatch updated to ${data.dispatch_status} status`);
        setSaving(false);
        onClose();
        // Refresh orders list to show updated status
        if (onRefresh) onRefresh();
      } else {
        // Initial dispatch: create dispatch record AND save dispatch quantities
        const finalForm = { ...form, ...imageMetadata };

        // First, dispatch the order
        const dispatchRes = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(finalForm)
        });

        if (!dispatchRes.ok) {
          const err = await dispatchRes.json();
          throw new Error(err.error || 'Failed to dispatch order');
        }

        // Then save dispatch quantities
        const dispatchQuantities = items.map((item, idx) => ({
          item_id: item.item_id,
          dispatch_bags: parseInt(form[`dispatch_bags_${idx}`] || 0),
          dispatch_quantity: parseFloat(form[`dispatch_quantity_${idx}`] || 0),
          dispatch_comments: form.dispatch_comments || ''
        }));

        const qtyRes = await fetch(`/api/dispatcher/orders/${order.order_id}/dispatch-quantities`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ dispatchQuantities })
        });

        if (!qtyRes.ok) {
          const err = await qtyRes.json();
          throw new Error(err.error || 'Failed to save dispatch quantities');
        }

        notify(`✅ Order #${order.order_id} dispatched successfully`);
        onClose();
        // Refresh orders list to show updated status
        if (onRefresh) onRefresh();
      }
    } catch (e) {
      setErr(e.message);
    }
    setSaving(false);
  };

  return (
    <div className="modal d-block" tabIndex="-1" style={{ background: 'rgba(0,0,0,0.55)' }}>
      <div className="modal-dialog modal-dialog-centered modal-lg">
        <div className="modal-content">

          <div className="modal-header" style={{ background: '#198754', color: '#fff' }}>
            <h5 className="modal-title">
              🚛 Dispatch — Order #{order.order_id}
            </h5>
            <button type="button" className="btn-close btn-close-white" onClick={onClose}></button>
          </div>

          <div className="modal-body">
            {/* Order summary */}
            <div className="row g-2 mb-4 p-3 rounded" style={{ background: '#f8faff' }}>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Dealer</div>
                <div className="fw-semibold">{order.dealer_login_name || order.dealer_company_name || order.dealer_name}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Order Time</div>
                <div className="fw-semibold" style={{ fontSize: '.85rem' }}>{fmt(order.order_date)}</div>
              </div>
              {/* Products & Quantities — with dispatch columns in edit mode */}
              <div className="col-12">
                <div className="text-muted small mb-1 fw-semibold">Products &amp; Quantities</div>
                <div style={{ overflowX: 'auto' }}>
                  <table className="table table-sm table-bordered mb-0" style={{ fontSize: '.80rem', background: '#fff', minWidth: '100%' }}>
                    <thead className="table-light">
                      <tr>
                        <th style={{ minWidth: 150 }}>Product</th>
                        <th style={{ width: 70 }}>Bags</th>
                        <th style={{ width: 90 }}>Qty (MT)</th>
                        <th style={{ width: 70, background: '#e3f2fd' }}>Dispatch Bags</th>
                        <th style={{ width: 90, background: '#e3f2fd' }}>Dispatch Qty</th>
                      </tr>
                    </thead>
                    <tbody>
                      {items && items.length > 0 ? (
                        items.map((item, idx) => (
                          <tr key={idx}>
                            <td>{item.product_name || `#${item.product_id}`}</td>
                            <td>{item.order_bags || '—'}</td>
                            <td>{parseFloat(item.order_quantity).toFixed(3)}</td>
                            <td style={{ background: '#f5f5f5' }}>
                              <input
                                type="number"
                                min="0"
                                max={item.order_bags}
                                step="1"
                                className="form-control form-control-sm"
                                value={form[`dispatch_bags_${idx}`] !== undefined ? form[`dispatch_bags_${idx}`] : (item.order_dispatch_bags || item.order_bags || 0)}
                                onChange={(e) => {
                                  let value = e.target.value;
                                  let bags = value === '' ? '' : parseInt(value) || 0;
                                  // Cap the value at order_bags
                                  if (bags !== '' && bags > parseInt(item.order_bags)) {
                                    bags = parseInt(item.order_bags);
                                  }
                                  const qtyPerBag = parseFloat(item.order_quantity || 0) / parseInt(item.order_bags || 1);
                                  const qty = bags === '' ? '' : (bags * qtyPerBag).toFixed(3);
                                  setForm(f => ({ ...f, [`dispatch_bags_${idx}`]: bags, [`dispatch_quantity_${idx}`]: qty }));
                                }}
                                title={`Maximum: ${item.order_bags} bags`}
                              />
                            </td>
                            <td style={{ background: '#f5f5f5' }}>
                              <input
                                type="number"
                                step="0.001"
                                className="form-control form-control-sm bg-light"
                                value={form[`dispatch_quantity_${idx}`] !== undefined ? form[`dispatch_quantity_${idx}`] : (item.order_dispatch_quantity || item.order_quantity || 0)}
                                readOnly
                              />
                            </td>
                          </tr>
                        ))
                      ) : (
                        <tr>
                          <td>{order.product_name || '—'}</td>
                          <td>—</td>
                          <td>{parseFloat(order.order_quantity || 0).toFixed(3)}</td>
                          <td style={{ background: '#f5f5f5' }}>
                            <input
                              type="number"
                              min="0"
                              max={order.bags}
                              step="1"
                              className="form-control form-control-sm"
                              value={form.dispatch_bags !== undefined ? form.dispatch_bags : (order.order_dispatch_bags || order.bags || 0)}
                              onChange={(e) => {
                                let value = e.target.value;
                                let bags = value === '' ? '' : parseInt(value) || 0;
                                // Cap the value at order_bags
                                if (bags !== '' && bags > parseInt(order.bags)) {
                                  bags = parseInt(order.bags);
                                }
                                const qtyPerBag = parseFloat(order.order_quantity || order.quantity || 0) / parseInt(order.bags || 1);
                                const qty = bags === '' ? '' : (bags * qtyPerBag).toFixed(3);
                                setForm(f => ({ ...f, dispatch_bags: bags, dispatch_quantity: qty }));
                              }}
                              title={`Maximum: ${order.bags} bags`}
                            />
                          </td>
                          <td style={{ background: '#f5f5f5' }}>
                            <input
                              type="number"
                              step="0.001"
                              className="form-control form-control-sm bg-light"
                              value={form.dispatch_quantity !== undefined ? form.dispatch_quantity : (order.order_dispatch_quantity || order.order_quantity || 0)}
                              readOnly
                            />
                          </td>
                        </tr>
                      )}
                    </tbody>
                    {items && items.length > 1 && (
                      <tfoot>
                        <tr className="table-secondary fw-bold">
                          <td colSpan="3" className="text-muted small text-end">Total</td>
                          <td style={{ background: '#e0e0e0' }}>
                            {items.reduce((s, i, idx) => s + (parseInt(form[`dispatch_bags_${idx}`] !== undefined ? form[`dispatch_bags_${idx}`] : (i.order_dispatch_bags || i.order_bags || 0))), 0)}
                          </td>
                          <td style={{ background: '#e0e0e0' }}>
                            {items.reduce((s, i, idx) => s + parseFloat(form[`dispatch_quantity_${idx}`] !== undefined ? form[`dispatch_quantity_${idx}`] : (i.order_dispatch_quantity || i.order_quantity || 0)), 0).toFixed(3)}
                          </td>
                        </tr>
                      </tfoot>
                    )}
                  </table>
                </div>
              </div>

              <div className="col-6 col-md-4">
                <div className="text-muted small">Party</div>
                <div className="fw-semibold">{order.party_company_name || order.party_name_col || '—'}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Delivery Address</div>
                <div className="fw-semibold">{order.party_address || '—'}</div>
              </div>
              <div className="col-6 col-md-4">
                <div className="text-muted small">Party Phone</div>
                <div className="fw-semibold">
                  {order.party_phone
                    ? <a href={`tel:${order.party_phone}`}>{order.party_phone}</a>
                    : '—'}
                </div>
              </div>
              <div className="col-6 col-md-6">
                <div className="text-muted small">Load Type</div>
                <div className="fw-semibold">{order.load_type_desc || order.load_type_code || '—'}</div>
